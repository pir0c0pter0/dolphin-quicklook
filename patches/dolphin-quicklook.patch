+bool QuickLookOverlay::probeGpuAvailability()
+{
+#ifdef HAVE_OPENGL
+    QOffscreenSurface surface;
+    surface.create();
+    if (!surface.isValid()) {
+        return false;
+    }
+
+    QOpenGLContext context;
+    if (!context.create()) {
+        return false;
+    }
+
+    if (!context.makeCurrent(&surface)) {
+        return false;
+    }
+
+    const auto version = context.format().version();
+    const bool isES = context.isOpenGLES();
+    const bool sufficient = isES ? (version.first >= 2) : (version.first >= 3 || (version.first == 2 && version.second >= 1));
+
+    const char *rendererStr = reinterpret_cast<const char *>(context.functions()->glGetString(GL_RENDERER));
+    const QString renderer = rendererStr ? QString::fromLatin1(rendererStr) : QString();
+
+    const bool softwareRenderer = renderer.contains(QLatin1String("llvmpipe"), Qt::CaseInsensitive)
+        || renderer.contains(QLatin1String("softpipe"), Qt::CaseInsensitive) || renderer.contains(QLatin1String("swrast"), Qt::CaseInsensitive);
+
+    context.doneCurrent();
+    return sufficient && !softwareRenderer;
+#else
+    return false;
+#endif
+}
