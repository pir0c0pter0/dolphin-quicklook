+ */
+
+#ifndef QUICKLOOKGLRENDERER_H
+#define QUICKLOOKGLRENDERER_H
+
+#include "quicklookrenderer.h"
+
+#include <QOpenGLBuffer>
+#include <QOpenGLFunctions>
+#include <QOpenGLShaderProgram>
+#include <QOpenGLTexture>
+#include <QOpenGLVertexArrayObject>
+#include <QOpenGLWidget>
+
+#include <memory>
+
+class QuickLookGLRenderer : public QuickLookRenderer
+{
+public:
+    explicit QuickLookGLRenderer(QWidget *parent);
+    ~QuickLookGLRenderer() override;
+
+    void initialize() override;
+    void resize(int w, int h) override;
+    void uploadContent(const QImage &image, int slot = 0) override;
+    void uploadCrossfadeContent(const QImage &newImage, const QImage &oldImage) override;
+    void render(const RenderState &state) override;
+    void cleanup() override;
+    bool isAccelerated() const override
+    {
+        return true;
+    }
+    QWidget *renderWidget() const override;
+
+private:
+    class GLWidget;
+
+    void initializeShaders();
+    void initializeGeometry();
+    void uploadTexture(int slot, const QImage &image);
+
+    GLWidget *m_glWidget = nullptr;
+
+    std::unique_ptr<QOpenGLShaderProgram> m_shader;
+    QOpenGLVertexArrayObject m_vao;
+    QOpenGLBuffer m_vbo{QOpenGLBuffer::VertexBuffer};
+
+    // Texture slots: 0 = current content, 1 = crossfade old content, 2 = text label
+    static constexpr int TextureSlots = 3;
+    std::unique_ptr<QOpenGLTexture> m_textures[TextureSlots];
+    QSize m_textureSize[TextureSlots];
+    bool m_textureValid[TextureSlots] = {};
+
+    // Cached text label to avoid re-rendering
+    QString m_cachedLabelText;
+    QImage m_labelImage;
+
+    // Pending render state (set before paintGL)
+    RenderState m_pendingState;
+    bool m_hasPendingState = false;
+
+    // GL is initialized
+    bool m_glInitialized = false;
+
+    // Pending texture uploads (queued before GL init)
+    QImage m_pendingUploads[TextureSlots];
+    bool m_hasPendingUpload[TextureSlots] = {};
+    void flushPendingUploads();
+
+    friend class GLWidget;
+};
+
+#endif // QUICKLOOKGLRENDERER_H
