+
+class QuickLookSWRenderer : public QuickLookRenderer
+{
+public:
+    explicit QuickLookSWRenderer(QWidget *parent);
+    ~QuickLookSWRenderer() override = default;
+
+    void initialize() override;
+    void resize(int w, int h) override;
+    void uploadContent(const QImage &image, int slot = 0) override;
