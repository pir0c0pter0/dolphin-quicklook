+void computeFFT(std::vector<std::complex<float>> &data)
+{
+    const int n = static_cast<int>(data.size());
+    if (n <= 1) {
+        return;
+    }
+
+    for (int i = 1, j = 0; i < n; i++) {
+        int bit = n >> 1;
+        for (; j & bit; bit >>= 1) {
+            j ^= bit;
+        }
+        j ^= bit;
+        if (i < j) {
+            std::swap(data[i], data[j]);
+        }
+    }
+
+    for (int len = 2; len <= n; len <<= 1) {
+        const auto angle = static_cast<float>(-2.0 * M_PI / len);
+        const std::complex<float> wn(std::cos(angle), std::sin(angle));
+        for (int i = 0; i < n; i += len) {
+            std::complex<float> w(1.0f);
+            for (int j = 0; j < len / 2; j++) {
+                auto u = data[i + j];
+                auto v = data[i + j + len / 2] * w;
+                data[i + j] = u + v;
+                data[i + j + len / 2] = u - v;
+                w *= wn;
+            }
+        }
+    }
+}
+
+QVector<float> computeSpectrum(const QVector<float> &samples, int offset, int windowSize, int numBars)
+{
+    std::vector<std::complex<float>> fftData(windowSize);
+
+    for (int i = 0; i < windowSize; i++) {
+        int idx = offset - windowSize / 2 + i;
+        float sample = (idx >= 0 && idx < samples.size()) ? samples[idx] : 0.0f;
+        float window = 0.5f * (1.0f - std::cos(2.0f * static_cast<float>(M_PI) * i / (windowSize - 1)));
+        fftData[i] = std::complex<float>(sample * window, 0.0f);
+    }
+
+    computeFFT(fftData);
+
+    QVector<float> bars(numBars, 0.0f);
+    const int halfN = windowSize / 2;
+
+    for (int i = 0; i < numBars; i++) {
+        float t0 = static_cast<float>(i) / numBars;
+        float t1 = static_cast<float>(i + 1) / numBars;
+        int bin0 = qMax(1, static_cast<int>(1.0f + (halfN - 1.0f) * t0 * t0));
+        int bin1 = qMax(bin0 + 1, static_cast<int>(1.0f + (halfN - 1.0f) * t1 * t1));
+        bin1 = qMin(bin1, halfN);
+
+        float sum = 0.0f;
+        int count = 0;
+        for (int b = bin0; b < bin1; b++) {
+            sum += std::abs(fftData[b]);
+            count++;
+        }
+        bars[i] = count > 0 ? sum / count : 0.0f;
+    }
+
+    float maxVal = 0.001f;
+    for (const auto &v : bars) {
+        maxVal = qMax(maxVal, v);
+    }
+    for (auto &v : bars) {
+        v /= maxVal;
+    }
+
+    return bars;
+}
 #endif
 }
 
