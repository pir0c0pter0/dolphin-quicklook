+    void uploadCrossfadeToRenderer(const QImage &newImage, const QImage &oldImage);
+
+    // Renderer (GPU or CPU fallback)
+    std::unique_ptr<QuickLookRenderer> m_renderer;
+
+    QImage m_contentImage;
+    QImage m_crossfadeOldImage;
+    QPixmap m_pixmap; // kept for SW path compatibility and size calculations
