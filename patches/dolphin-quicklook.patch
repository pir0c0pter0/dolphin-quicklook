diff --git a/src/views/quicklookoverlay.cpp b/src/views/quicklookoverlay.cpp
new file mode 100644
index 000000000..55bff4360
--- /dev/null
+++ b/src/views/quicklookoverlay.cpp
@@ -0,0 +1,433 @@
+/*
+ * SPDX-FileCopyrightText: 2026 Mario STJr
+ *
+ * SPDX-License-Identifier: GPL-2.0-or-later
+ */
+
+#include "quicklookoverlay.h"
+
+#include <QAudioOutput>
+#include <QEasingCurve>
+#include <QImageReader>
+#include <QKeyEvent>
+#include <QLabel>
+#include <QMediaPlayer>
+#include <QMimeDatabase>
+#include <QMouseEvent>
+#include <QPainter>
+#include <QPainterPath>
+#include <QPropertyAnimation>
+#include <QResizeEvent>
+#include <QVideoWidget>
+
+#ifdef HAVE_POPPLER
+#include <poppler-qt6.h>
+#endif
+
+QuickLookOverlay::QuickLookOverlay(QWidget *parent)
+    : QWidget(parent)
+    , m_animationProgress(0.0)
+    , m_active(false)
+    , m_contentType(ContentType::Image)
+    , m_animation(new QPropertyAnimation(this, "animationProgress", this))
+    , m_mediaPlayer(nullptr)
+    , m_videoWidget(nullptr)
+    , m_audioOutput(nullptr)
+{
+    setFocusPolicy(Qt::StrongFocus);
+    hide();
+
+    m_animation->setDuration(250);
+    m_animation->setEasingCurve(QEasingCurve::OutCubic);
+}
+
+QuickLookOverlay::~QuickLookOverlay()
+{
+    cleanupVideo();
+}
+
+bool QuickLookOverlay::isSupportedMimeType(const QString &mimeType)
+{
+    // Images
+    if (mimeType.startsWith(QLatin1String("image/"))) {
+        return true;
+    }
+
+    // PDF
+    if (mimeType == QLatin1String("application/pdf")) {
+#ifdef HAVE_POPPLER
+        return true;
+#else
+        return false;
+#endif
+    }
+
+    // Video
+    static const QStringList videoTypes = {
+        QStringLiteral("video/mp4"),
+        QStringLiteral("video/x-matroska"),
+        QStringLiteral("video/webm"),
+        QStringLiteral("video/avi"),
+        QStringLiteral("video/x-msvideo"),
+        QStringLiteral("video/quicktime"),
+        QStringLiteral("video/ogg"),
+        QStringLiteral("video/x-flv"),
+        QStringLiteral("video/3gpp"),
+        QStringLiteral("video/mpeg"),
+    };
+    if (videoTypes.contains(mimeType)) {
+        return true;
+    }
+
+    return false;
+}
+
+bool QuickLookOverlay::loadImage(const QString &filePath)
+{
+    QImageReader reader(filePath);
+    reader.setAutoTransform(true);
+    const QImage image = reader.read();
+    if (image.isNull()) {
+        return false;
+    }
+    m_pixmap = QPixmap::fromImage(image);
+    m_contentType = ContentType::Image;
+    m_statusText.clear();
+    return true;
+}
+
+bool QuickLookOverlay::loadPdf(const QString &filePath)
+{
+#ifdef HAVE_POPPLER
+    auto document = Poppler::Document::load(filePath);
+    if (!document) {
+        return false;
+    }
+
+    document->setRenderHint(Poppler::Document::Antialiasing);
+    document->setRenderHint(Poppler::Document::TextAntialiasing);
+
+    auto page = document->page(0);
+    if (!page) {
+        return false;
+    }
+
+    // Render at 2x for crisp display
+    const QImage image = page->renderToImage(144, 144);
+    if (image.isNull()) {
+        return false;
+    }
+
+    m_pixmap = QPixmap::fromImage(image);
+    m_contentType = ContentType::Pdf;
+
+    const int totalPages = document->numPages();
+    m_statusText = (totalPages > 1)
+        ? QStringLiteral(" — %1 pages").arg(totalPages)
+        : QStringLiteral(" — 1 page");
+
+    return true;
+#else
+    Q_UNUSED(filePath)
+    return false;
+#endif
+}
+
+void QuickLookOverlay::setupVideo(const QUrl &fileUrl)
+{
+    cleanupVideo();
+
+    m_contentType = ContentType::Video;
+    m_pixmap = QPixmap(); // no static pixmap for video
+    m_statusText.clear();
+
+    m_audioOutput = new QAudioOutput(this);
+    m_audioOutput->setVolume(0.5);
+
+    m_mediaPlayer = new QMediaPlayer(this);
+    m_mediaPlayer->setAudioOutput(m_audioOutput);
+
+    m_videoWidget = new QVideoWidget(this);
+    m_videoWidget->setStyleSheet(QStringLiteral("background: transparent;"));
+    m_mediaPlayer->setVideoOutput(m_videoWidget);
+
+    m_mediaPlayer->setSource(fileUrl);
+    m_mediaPlayer->setLoops(QMediaPlayer::Infinite);
+
+    // Hide initially — will be shown during animation
+    m_videoWidget->hide();
+
+    connect(m_mediaPlayer, &QMediaPlayer::mediaStatusChanged, this, [this](QMediaPlayer::MediaStatus status) {
+        if (status == QMediaPlayer::LoadedMedia || status == QMediaPlayer::BufferedMedia) {
+            m_mediaPlayer->play();
+            updateVideoGeometry();
+            m_videoWidget->show();
+            m_videoWidget->raise();
+        }
+    });
+}
+
+void QuickLookOverlay::cleanupVideo()
+{
+    if (m_mediaPlayer) {
+        m_mediaPlayer->stop();
+        delete m_mediaPlayer;
+        m_mediaPlayer = nullptr;
+    }
+    if (m_videoWidget) {
+        delete m_videoWidget;
+        m_videoWidget = nullptr;
+    }
+    if (m_audioOutput) {
+        delete m_audioOutput;
+        m_audioOutput = nullptr;
+    }
+}
+
+void QuickLookOverlay::updateVideoGeometry()
+{
+    if (!m_videoWidget) {
+        return;
+    }
+
+    const QRect targetRect = scaledContentRect();
+    const QPointF center = QRectF(targetRect).center();
+    const qreal scale = 0.3 + 0.7 * m_animationProgress;
+    const qreal w = targetRect.width() * scale;
+    const qreal h = targetRect.height() * scale;
+    const QRect videoRect(
+        static_cast<int>(center.x() - w / 2.0),
+        static_cast<int>(center.y() - h / 2.0),
+        static_cast<int>(w),
+        static_cast<int>(h)
+    );
+    m_videoWidget->setGeometry(videoRect);
+
+    const int alpha = static_cast<int>(255 * m_animationProgress);
+    m_videoWidget->setVisible(alpha > 10);
+}
+
+void QuickLookOverlay::showPreview(const QUrl &fileUrl)
+{
+    if (!fileUrl.isLocalFile()) {
+        return;
+    }
+
+    const QString filePath = fileUrl.toLocalFile();
+    QMimeDatabase mimeDb;
+    const QString mimeType = mimeDb.mimeTypeForFile(filePath).name();
+
+    bool loaded = false;
+
+    if (mimeType.startsWith(QLatin1String("image/"))) {
+        loaded = loadImage(filePath);
+    } else if (mimeType == QLatin1String("application/pdf")) {
+        loaded = loadPdf(filePath);
+    } else if (mimeType.startsWith(QLatin1String("video/"))) {
+        setupVideo(fileUrl);
+        loaded = true;
+    }
+
+    if (!loaded) {
+        return;
+    }
+
+    m_currentUrl = fileUrl;
+    m_active = true;
+
+    resize(parentWidget()->size());
+    show();
+    raise();
+    setFocus();
+
+    startShowAnimation();
+}
+
+void QuickLookOverlay::hidePreview()
+{
+    if (!m_active) {
+        return;
+    }
+    if (m_mediaPlayer) {
+        m_mediaPlayer->pause();
+    }
+    startHideAnimation();
+}
+
+bool QuickLookOverlay::isPreviewActive() const
+{
+    return m_active;
+}
+
+qreal QuickLookOverlay::animationProgress() const
+{
+    return m_animationProgress;
+}
+
+void QuickLookOverlay::setAnimationProgress(qreal progress)
+{
+    m_animationProgress = progress;
+    update();
+
+    if (m_contentType == ContentType::Video) {
+        updateVideoGeometry();
+    }
+
+    if (progress <= 0.0 && m_animation->direction() == QAbstractAnimation::Backward) {
+        m_active = false;
+        cleanupVideo();
+        hide();
+        Q_EMIT previewClosed();
+    }
+}
+
+void QuickLookOverlay::paintEvent(QPaintEvent *event)
+{
+    Q_UNUSED(event)
+
+    QPainter painter(this);
+    painter.setRenderHint(QPainter::Antialiasing);
+    painter.setRenderHint(QPainter::SmoothPixmapTransform);
+
+    // Background overlay with animated opacity
+    const int bgAlpha = static_cast<int>(180 * m_animationProgress);
+    painter.fillRect(rect(), QColor(0, 0, 0, bgAlpha));
+
+    if (m_contentType == ContentType::Video) {
+        // Video widget handles its own rendering; just draw filename
+        const QRect targetRect = scaledContentRect();
+        const QPointF center = QRectF(targetRect).center();
+        const qreal scale = 0.3 + 0.7 * m_animationProgress;
+        const qreal h = targetRect.height() * scale;
+        const qreal drawBottom = center.y() + h / 2.0;
+
+        // Drop shadow for video area
+        if (m_videoWidget && m_videoWidget->isVisible()) {
+            const int shadowOffset = static_cast<int>(4 * m_animationProgress);
+            const int shadowAlpha = static_cast<int>(80 * m_animationProgress);
+            QRectF shadowRect = QRectF(m_videoWidget->geometry()).adjusted(shadowOffset, shadowOffset, shadowOffset, shadowOffset);
+            painter.setPen(Qt::NoPen);
+            painter.setBrush(QColor(0, 0, 0, shadowAlpha));
+            painter.drawRoundedRect(shadowRect, 6, 6);
+        }
+
+        // Filename
+        const QString filename = m_currentUrl.fileName();
+        const int textAlpha = static_cast<int>(255 * m_animationProgress);
+        painter.setPen(QColor(255, 255, 255, textAlpha));
+        QFont font = painter.font();
+        font.setPointSize(11);
+        font.setBold(true);
+        painter.setFont(font);
+
+        const QRect textRect(0, static_cast<int>(drawBottom) + 12, width(), 30);
+        painter.drawText(textRect, Qt::AlignHCenter | Qt::AlignTop, filename);
+        return;
+    }
+
+    // Image / PDF rendering
+    if (m_pixmap.isNull()) {
+        return;
+    }
+
+    const QRect targetRect = scaledContentRect();
+    const QPointF center = QRectF(targetRect).center();
+    const qreal scale = 0.3 + 0.7 * m_animationProgress;
+    const qreal w = targetRect.width() * scale;
+    const qreal h = targetRect.height() * scale;
+    const QRectF drawRect(center.x() - w / 2.0, center.y() - h / 2.0, w, h);
+
+    // Drop shadow
+    const int shadowOffset = static_cast<int>(4 * m_animationProgress);
+    const int shadowAlpha = static_cast<int>(80 * m_animationProgress);
+    QRectF shadowRect = drawRect.adjusted(shadowOffset, shadowOffset, shadowOffset, shadowOffset);
+    painter.setPen(Qt::NoPen);
+    painter.setBrush(QColor(0, 0, 0, shadowAlpha));
+    painter.drawRoundedRect(shadowRect, 6, 6);
+
+    // Content with rounded corners
+    QPainterPath clipPath;
+    clipPath.addRoundedRect(drawRect, 6, 6);
+    painter.setClipPath(clipPath);
+    painter.drawPixmap(drawRect.toRect(), m_pixmap);
+    painter.setClipping(false);
+
+    // Filename + status text at the bottom
+    const QString label = m_currentUrl.fileName() + m_statusText;
+    const int textAlpha = static_cast<int>(255 * m_animationProgress);
+    painter.setPen(QColor(255, 255, 255, textAlpha));
+    QFont font = painter.font();
+    font.setPointSize(11);
+    font.setBold(true);
+    painter.setFont(font);
+
+    const QRect textRect(0, drawRect.bottom() + 12, width(), 30);
+    painter.drawText(textRect, Qt::AlignHCenter | Qt::AlignTop, label);
+}
+
+void QuickLookOverlay::mouseDoubleClickEvent(QMouseEvent *event)
+{
+    Q_UNUSED(event)
+    hidePreview();
+}
+
+void QuickLookOverlay::keyPressEvent(QKeyEvent *event)
+{
+    if (event->key() == Qt::Key_Escape || event->key() == Qt::Key_Space) {
+        hidePreview();
+        event->accept();
+        return;
+    }
+    QWidget::keyPressEvent(event);
+}
+
+void QuickLookOverlay::resizeEvent(QResizeEvent *event)
+{
+    QWidget::resizeEvent(event);
+    if (m_contentType == ContentType::Video) {
+        updateVideoGeometry();
+    }
+    update();
+}
+
+void QuickLookOverlay::startShowAnimation()
+{
+    m_animation->stop();
+    m_animation->setDirection(QAbstractAnimation::Forward);
+    m_animation->setStartValue(0.0);
+    m_animation->setEndValue(1.0);
+    m_animation->start();
+}
+
+void QuickLookOverlay::startHideAnimation()
+{
+    m_animation->stop();
+    m_animation->setDirection(QAbstractAnimation::Backward);
+    m_animation->setStartValue(0.0);
+    m_animation->setEndValue(1.0);
+    m_animation->start();
+}
+
+QRect QuickLookOverlay::scaledContentRect() const
+{
+    const int padding = 40;
+    const int maxW = width() - 2 * padding;
+    const int maxH = height() - 2 * padding - 50;
+
+    QSize contentSize;
+    if (m_contentType == ContentType::Video) {
+        // Default 16:9 aspect ratio for video
+        contentSize = QSize(1280, 720);
+    } else if (!m_pixmap.isNull()) {
+        contentSize = m_pixmap.size();
+    } else {
+        return {};
+    }
+
+    contentSize.scale(maxW, maxH, Qt::KeepAspectRatio);
+
+    const int x = (width() - contentSize.width()) / 2;
+    const int y = (height() - contentSize.height()) / 2 - 20;
+
+    return {x, y, contentSize.width(), contentSize.height()};
+}
