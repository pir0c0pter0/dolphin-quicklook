+void QuickLookOverlay::setupAudio(const QUrl &fileUrl)
+{
+    cleanupVideo();
+    cleanupAudio();
+
+    m_contentType = ContentType::Audio;
+    m_audioPhase = AudioPhase::Animating;
+    m_vinylAngle = 0.0;
+    m_audioSamples.clear();
+    m_audioDecodingDone = false;
+    m_smoothedSpectrum.clear();
+    m_statusText.clear();
+
+    // Generate vinyl image (cached across calls)
+    if (m_vinylImage.isNull()) {
+        m_vinylImage = generateVinylImage(AudioComposeSize);
+    }
+
+    // Compose initial static frame (non-rotated vinyl)
+    m_contentImage = m_vinylImage.copy();
+    m_pixmap = QPixmap::fromImage(m_contentImage);
+
+    // Set up audio playback
+    m_audioOutput = new QAudioOutput(this);
+    m_audioOutput->setVolume(DefaultVolume);
+
+    m_mediaPlayer = new QMediaPlayer(this);
+    m_mediaPlayer->setAudioOutput(m_audioOutput);
+    m_mediaPlayer->setSource(fileUrl);
+    m_mediaPlayer->setLoops(QMediaPlayer::Infinite);
+
+    // Update status text with playback time
+    connect(m_mediaPlayer, &QMediaPlayer::positionChanged, this, [this](qint64 pos) {
+        if (m_contentType != ContentType::Audio) {
+            return;
+        }
+        const qint64 dur = m_mediaPlayer->duration() / 1000;
+        const qint64 cur = pos / 1000;
+        m_statusText =
+            QStringLiteral(" — %1:%2 / %3:%4").arg(cur / 60).arg(cur % 60, 2, 10, QLatin1Char('0')).arg(dur / 60).arg(dur % 60, 2, 10, QLatin1Char('0'));
+    });
+
+    // Set up audio decoder for spectrum data
+    m_audioDecoder = new QAudioDecoder(this);
+    QAudioFormat format;
+    format.setSampleRate(44100);
+    format.setChannelCount(1);
+    format.setSampleFormat(QAudioFormat::Float);
+    m_audioDecoder->setAudioFormat(format);
+    m_audioDecoder->setSource(fileUrl);
+    m_audioSampleRate = 44100;
+
+    connect(m_audioDecoder, &QAudioDecoder::bufferReady, this, [this]() {
+        if (m_audioSamples.size() >= MaxAudioDecodeSamples) {
+            return;
+        }
+        const QAudioBuffer buffer = m_audioDecoder->read();
+        if (!buffer.isValid()) {
+            return;
+        }
+        const float *data = buffer.constData<float>();
+        const int count = buffer.frameCount();
+        for (int i = 0; i < count && m_audioSamples.size() < MaxAudioDecodeSamples; i++) {
+            m_audioSamples.append(data[i]);
+        }
+    });
+
+    connect(m_audioDecoder, &QAudioDecoder::finished, this, [this]() {
+        m_audioDecodingDone = true;
+    });
+
+    m_audioDecoder->start();
+
+    // Show and animate
+    if (!parentWidget()) {
+        return;
+    }
+    move(0, 0);
+    resize(parentWidget()->size());
+
+    if (m_renderer) {
+        m_renderer->resize(width(), height());
+    }
+
+    show();
+    raise();
+    setFocus();
+
+    uploadContentToRenderer();
+    startShowAnimation();
+}
+
+void QuickLookOverlay::cleanupAudio()
+{
+    if (m_vinylTimer) {
+        m_vinylTimer->stop();
+        m_vinylTimer->deleteLater();
+        m_vinylTimer = nullptr;
+    }
+    if (m_audioDecoder) {
+        m_audioDecoder->stop();
+        m_audioDecoder->deleteLater();
+        m_audioDecoder = nullptr;
+    }
+    if (m_contentType == ContentType::Audio) {
+        if (m_mediaPlayer) {
+            m_mediaPlayer->stop();
+            m_mediaPlayer->deleteLater();
+            m_mediaPlayer = nullptr;
+        }
+        if (m_audioOutput) {
+            m_audioOutput->deleteLater();
+            m_audioOutput = nullptr;
+        }
+    }
+    m_audioSamples.clear();
+    m_audioSamples.squeeze();
+    m_smoothedSpectrum.clear();
+    m_audioDecodingDone = false;
+}
+
+void QuickLookOverlay::composeAudioFrame()
+{
+    if (!m_active || m_contentType != ContentType::Audio) {
+        return;
+    }
+
+    const int sz = AudioComposeSize;
+    QImage frame(sz, sz, QImage::Format_ARGB32_Premultiplied);
+    frame.fill(Qt::transparent);
+
+    QPainter painter(&frame);
+    painter.setRenderHint(QPainter::Antialiasing);
+    painter.setRenderHint(QPainter::SmoothPixmapTransform);
+
+    // Draw rotated vinyl
+    const QPointF center(sz / 2.0, sz / 2.0);
+    painter.translate(center);
+    painter.rotate(m_vinylAngle);
+    painter.translate(-center);
+    painter.drawImage(QRect(0, 0, sz, sz), m_vinylImage);
+
+    // Draw spectrum in center
+    if (!m_audioSamples.isEmpty() && m_mediaPlayer && m_audioPhase == AudioPhase::Playing) {
+        painter.resetTransform();
+        painter.translate(center);
+
+        const qint64 posMs = m_mediaPlayer->position();
+        const int sampleOffset = static_cast<int>(posMs * m_audioSampleRate / 1000.0);
+
+        QVector<float> spectrum = computeSpectrum(m_audioSamples, sampleOffset, FftWindowSize, SpectrumBarCount);
+
+        // Smooth with previous frame (exponential decay)
+        if (m_smoothedSpectrum.size() != SpectrumBarCount) {
+            m_smoothedSpectrum.resize(SpectrumBarCount);
+            m_smoothedSpectrum.fill(0.0f);
+        }
+        for (int i = 0; i < SpectrumBarCount; i++) {
+            m_smoothedSpectrum[i] = 0.35f * spectrum[i] + 0.65f * m_smoothedSpectrum[i];
+        }
+
+        // Radial spectrum bars
+        const float innerR = sz * 0.04f;
+        const float outerR = sz * VinylLabelRatio * 0.48f;
+        const float barAngleStep = 360.0f / SpectrumBarCount;
+        const float barWidth = 3.5f;
+
+        for (int i = 0; i < SpectrumBarCount; i++) {
+            const float angle = barAngleStep * i;
+            const float magnitude = m_smoothedSpectrum[i];
+            const float barLen = qMax(2.0f, magnitude * (outerR - innerR));
+
+            painter.save();
+            painter.rotate(static_cast<qreal>(angle));
+
+            QRectF bar(innerR, -barWidth / 2.0, barLen, barWidth);
+            painter.setPen(Qt::NoPen);
+
+            QLinearGradient grad(innerR, 0, innerR + barLen, 0);
+            grad.setColorAt(0.0, QColor(100, 255, 50, 200));
+            grad.setColorAt(1.0, QColor(180, 255, 100, 240));
+            painter.setBrush(grad);
+
+            painter.drawRoundedRect(bar, 1.5, 1.5);
+            painter.restore();
+        }
+    }
+
+    painter.end();
+
+    m_contentImage = frame;
+    m_pixmap = QPixmap::fromImage(frame);
+    uploadContentToRenderer();
+    update();
+}
 #endif
 
