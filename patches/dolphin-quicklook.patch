new file mode 100644
index 000000000..b62ca8aee
--- /dev/null
+++ b/src/views/quicklookswrenderer.cpp
@@ -0,0 +1,203 @@
+/*
+ * SPDX-FileCopyrightText: 2026 Mario STJr
+ *
+ * SPDX-License-Identifier: GPL-2.0-or-later
+ */
+
+#include "quicklookswrenderer.h"
+
+#include <QPainter>
+#include <QPainterPath>
+#include <QWidget>
+
+namespace
+{
+constexpr int CornerRadius = 6;
+constexpr int ShadowOffset = 4;
+constexpr int TextSpacing = 12;
+constexpr int TextHeight = 30;
+constexpr int BgAlphaMax = 180;
+constexpr int ShadowAlphaMax = 80;
+constexpr int PdfCrossfadeDurationMs = 150;
+}
+
+QuickLookSWRenderer::QuickLookSWRenderer(QWidget *parent)
+    : m_parent(parent)
+{
+}
+
+void QuickLookSWRenderer::initialize()
+{
+}
+
+void QuickLookSWRenderer::resize(int /*w*/, int /*h*/)
+{
+}
+
+void QuickLookSWRenderer::uploadContent(const QImage &image, int slot)
+{
+    if (image.isNull()) {
+        return;
+    }
+    if (slot == 0) {
+        m_pixmap = QPixmap::fromImage(image);
+    } else if (slot == 1) {
+        m_crossfadeOldPixmap = QPixmap::fromImage(image);
+    }
+}
+
+void QuickLookSWRenderer::uploadCrossfadeContent(const QImage &newImage, const QImage &oldImage)
+{
+    m_pixmap = QPixmap::fromImage(newImage);
+    m_crossfadeOldPixmap = QPixmap::fromImage(oldImage);
+}
+
+void QuickLookSWRenderer::render(const RenderState &state)
+{
+    if (m_pixmap.isNull()) {
+        return;
+    }
+
+    QPainter painter(m_parent);
+    painter.setRenderHint(QPainter::Antialiasing);
+    painter.setRenderHint(QPainter::SmoothPixmapTransform);
+
+    const QColor bgColor(0, 0, 0, static_cast<int>(BgAlphaMax * state.animationProgress));
+    QColor shadowColor(0, 0, 0);
+    const QColor textColor(255, 255, 255, static_cast<int>(255 * state.animationProgress));
+    QFont labelFont = m_parent->font();
+    labelFont.setBold(true);
+
+    painter.fillRect(QRect(QPoint(0, 0), state.widgetSize), bgColor);
+
+    const QRect targetRect = state.drawRect.toRect();
+
+    // Video playing: draw at full size, no scale animation
+    if (state.isVideoPlaying) {
+        shadowColor.setAlpha(ShadowAlphaMax);
+        QRectF shadowRect = QRectF(targetRect).adjusted(0, 0, ShadowOffset, ShadowOffset);
+        painter.setPen(Qt::NoPen);
+        painter.setBrush(shadowColor);
+        painter.drawRoundedRect(shadowRect, CornerRadius, CornerRadius);
+
+        QPainterPath clipPath;
+        clipPath.addRoundedRect(QRectF(targetRect), CornerRadius, CornerRadius);
+        painter.setClipPath(clipPath);
+        painter.drawPixmap(targetRect, m_pixmap);
+        painter.setClipping(false);
+
+        painter.setPen(textColor);
+        painter.setFont(labelFont);
+        const QRect videoTextRect(0, state.anchorRect.bottom() + TextSpacing, state.widgetSize.width(), TextHeight);
+        painter.drawText(videoTextRect, Qt::AlignHCenter | Qt::AlignTop, state.labelText);
+        return;
+    }
+
+    // Image / PDF / Video thumbnail with scale animation
+    const QRectF drawRect = state.drawRect;
+
+    // Drop shadow
+    const int curShadowOffset = static_cast<int>(ShadowOffset * state.animationProgress);
+    shadowColor.setAlpha(static_cast<int>(ShadowAlphaMax * state.animationProgress));
+    QRectF shadowRect = drawRect.adjusted(curShadowOffset, curShadowOffset, curShadowOffset, curShadowOffset);
+    painter.setPen(Qt::NoPen);
+    painter.setBrush(shadowColor);
+    painter.drawRoundedRect(shadowRect, CornerRadius, CornerRadius);
+
+    // Content with rounded corners + fade
+    painter.setOpacity(state.animationProgress);
+    QPainterPath clipPath;
+    clipPath.addRoundedRect(drawRect, CornerRadius, CornerRadius);
+    painter.setClipPath(clipPath);
+
+    // Crossfade blend
+    if (state.hiResCrossfade < 1.0 && !m_crossfadeOldPixmap.isNull()) {
+        painter.setOpacity(state.animationProgress * (1.0 - state.hiResCrossfade));
+        painter.drawPixmap(drawRect.toRect(), m_crossfadeOldPixmap);
+
+        painter.setOpacity(state.animationProgress * state.hiResCrossfade);
+        painter.drawPixmap(drawRect.toRect(), m_pixmap);
+    } else {
+        painter.drawPixmap(drawRect.toRect(), m_pixmap);
+    }
+
+    painter.setClipping(false);
+    painter.setOpacity(1.0);
+
+    // Label — anchored to anchorRect (zoomed but not panned)
+    painter.setPen(textColor);
+    painter.setFont(labelFont);
+    const QRect textRect(0, state.anchorRect.bottom() + TextSpacing, state.widgetSize.width(), TextHeight);
+    painter.drawText(textRect, Qt::AlignHCenter | Qt::AlignTop, state.labelText);
+
+    // PDF loading spinner
+    if (state.pdfPageLoading && state.animationProgress > 0.5) {
+        const qreal spinnerSize = 40.0;
+        const qreal penWidth = 3.0;
+        const QPointF center = drawRect.center();
+        const QRectF spinnerRect(center.x() - spinnerSize / 2.0, center.y() - spinnerSize / 2.0, spinnerSize, spinnerSize);
+        const QRectF strokeRect = spinnerRect.adjusted(penWidth / 2.0, penWidth / 2.0, -penWidth / 2.0, -penWidth / 2.0);
+
+        // Dim overlay on content
+        painter.setOpacity(state.animationProgress * 0.3);
+        painter.setClipPath(clipPath);
+        painter.fillRect(drawRect.toRect(), QColor(0, 0, 0));
+        painter.setClipping(false);
+
+        // Smooth gradient spinner (conical gradient = no jagged edges)
+        painter.setOpacity(state.animationProgress * 0.9);
+        QConicalGradient gradient(center, state.spinnerAngle);
+        gradient.setColorAt(0.0, QColor(255, 255, 255, 230));
+        gradient.setColorAt(0.65, QColor(255, 255, 255, 40));
+        gradient.setColorAt(0.75, QColor(255, 255, 255, 0));
+        gradient.setColorAt(1.0, QColor(255, 255, 255, 0));
+
+        QPen spinnerPen(QBrush(gradient), penWidth, Qt::SolidLine, Qt::RoundCap);
+        painter.setPen(spinnerPen);
+        painter.setBrush(Qt::NoBrush);
+        painter.drawEllipse(strokeRect);
+        painter.setOpacity(1.0);
+    }
+
+    // PDF navigation arrows
+    if (state.showPdfArrows && state.animationProgress > 0.5) {
+        const int arrowSize = 36;
+
+        auto drawArrowButton = [&](const QRect &btnRect, bool enabled, bool pointsUp) {
+            const qreal btnOpacity = enabled ? 0.85 : 0.3;
+            painter.setOpacity(state.animationProgress * btnOpacity);
+
+            painter.setPen(Qt::NoPen);
+            painter.setBrush(QColor(255, 255, 255, 40));
+            painter.drawRoundedRect(btnRect, 8, 8);
+
+            const int pad = 10;
+            const QPointF c = QRectF(btnRect).center();
+            const int half = (arrowSize - 2 * pad) / 2;
+            QPolygonF triangle;
+            if (pointsUp) {
+                triangle << QPointF(c.x(), c.y() - half) << QPointF(c.x() - half, c.y() + half) << QPointF(c.x() + half, c.y() + half);
+            } else {
+                triangle << QPointF(c.x(), c.y() + half) << QPointF(c.x() - half, c.y() - half) << QPointF(c.x() + half, c.y() - half);
+            }
+            painter.setBrush(QColor(255, 255, 255));
+            painter.drawPolygon(triangle);
+        };
+
+        drawArrowButton(state.pdfArrowUpRect, state.canGoUp, true);
+        drawArrowButton(state.pdfArrowDownRect, state.canGoDown, false);
+
+        painter.setOpacity(1.0);
+    }
+}
+
+void QuickLookSWRenderer::cleanup()
+{
+    m_pixmap = QPixmap();
+    m_crossfadeOldPixmap = QPixmap();
+}
+
+QWidget *QuickLookSWRenderer::renderWidget() const
+{
+    return m_parent;
+}
