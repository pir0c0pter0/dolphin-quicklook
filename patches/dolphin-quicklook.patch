+#ifndef QUICKLOOKOVERLAY_H
+#define QUICKLOOKOVERLAY_H
+
+#include <QWidget>
+#include <QUrl>
+#include <QEasingCurve>
+#include <QElapsedTimer>
+#include <QPointF>
+
+#include <memory>
+#include <QFutureWatcher>
+#include <QHash>
+#include <QPixmap>
+
+class QLabel;
+class QTimer;
+
+#ifdef HAVE_POPPLER
+namespace Poppler {
+class Document;
+class Page;
+}
+#endif
+
+#ifdef HAVE_QTMULTIMEDIA
+class QMediaPlayer;
+class QVideoSink;
+class QAudioOutput;
+#endif
+
+class QuickLookOverlay : public QWidget
+{
+    Q_OBJECT
+    Q_PROPERTY(qreal animationProgress READ animationProgress WRITE setAnimationProgress)
+
+public:
+    explicit QuickLookOverlay(QWidget *parent = nullptr);
+    ~QuickLookOverlay() override;
+
+    void showPreview(const QUrl &fileUrl);
+    void hidePreview();
+    bool isPreviewActive() const;
+    static bool isSupportedMimeType(const QString &mimeType);
+
+    qreal animationProgress() const;
+    void setAnimationProgress(qreal progress);
+
+Q_SIGNALS:
+    void previewClosed();
+
+protected:
+    void paintEvent(QPaintEvent *event) override;
+    void mouseDoubleClickEvent(QMouseEvent *event) override;
+    void mousePressEvent(QMouseEvent *event) override;
+    void mouseMoveEvent(QMouseEvent *event) override;
+    void mouseReleaseEvent(QMouseEvent *event) override;
+    void wheelEvent(QWheelEvent *event) override;
+    void keyPressEvent(QKeyEvent *event) override;
+    void resizeEvent(QResizeEvent *event) override;
+
+private:
+    enum class ContentType {
+        Image,
+        Pdf,
+        Video,
+    };
+
+#ifdef HAVE_QTMULTIMEDIA
+    enum class VideoPhase {
+        Loading,
+        Animating,
+        Playing,
+        Closing,
+    };
+#endif
+
+    void startShowAnimation();
+    void startHideAnimation();
+    QRect scaledContentRect() const;
+
+    bool loadImage(const QString &filePath);
+    bool loadPdf(const QString &filePath);
+    void navigatePdfPage(int direction);
+    void renderPdfPage(int pageIndex);
+    void renderPdfPageAsync(int pageIndex);
+    void onPdfPageRenderFinished();
+    void prefetchAdjacentPages();
+    void updatePdfStatusText();
+
+#ifdef HAVE_QTMULTIMEDIA
+    void setupVideo(const QUrl &fileUrl);
+    void cleanupVideo();
+#endif
+
+    void advanceAnimation();
+    void advanceZoomAnimation();
+    void onAnimationFinished();
+    QRectF baseContentRect() const;
+    void resetZoom();
+    void animateZoomReset();
+    void scheduleHiResRerender();
+    void rerenderHiRes();
+    void onHiResRenderFinished();
+
+    QPixmap m_pixmap;
+    QUrl m_currentUrl;
+    qreal m_animationProgress;
+    bool m_active;
+    ContentType m_contentType;
+    QString m_statusText;
+
+    // PDF page navigation
+    int m_pdfCurrentPage = 0;
+    int m_pdfTotalPages = 0;
+    QRect m_pdfArrowUpRect;
+    QRect m_pdfArrowDownRect;
+
+    // PDF page cache (LRU, keyed by page index)
+    static constexpr int PdfCacheMaxPages = 5;
