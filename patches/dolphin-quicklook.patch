+    int m_pdfTotalPages = 0;
+    QRect m_pdfArrowUpRect;
+    QRect m_pdfArrowDownRect;
+
+    // PDF page cache (LRU, keyed by page index)
+    static constexpr int PdfCacheMaxPages = 5;
+    QHash<int, QImage> m_pdfPageCache;
+    QList<int> m_pdfCacheLru;
+    void pdfCacheInsert(int pageIndex, const QImage &image);
+    QImage pdfCacheLookup(int pageIndex);
+
+    // Progressive rendering (PDF + Image)
+    QString m_pdfFilePath;
+    QString m_imageFilePath;
+    QSize m_imageOriginalSize;
+    QTimer *m_hiResRenderTimer = nullptr;
+    qreal m_pdfRenderedDpi = 0.0;
+#ifdef HAVE_POPPLER
