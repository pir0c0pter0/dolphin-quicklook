+/*
+ * SPDX-FileCopyrightText: 2026 Mario STJr
+ *
+ * SPDX-License-Identifier: GPL-2.0-or-later
+ */
+
+#ifndef QUICKLOOKRENDERER_H
+#define QUICKLOOKRENDERER_H
+
+#include <QImage>
+#include <QPointF>
+#include <QRectF>
+#include <QSize>
+#include <QString>
+
+class QWidget;
+
+class QuickLookRenderer
+{
+public:
+    virtual ~QuickLookRenderer() = default;
+
+    struct RenderState {
+        qreal animationProgress = 0.0;
+        qreal zoomFactor = 1.0;
+        QPointF panOffset;
+        QRectF baseContentRect;
+        QRectF drawRect;
+        QRectF anchorRect; // zoomed but not panned — for label/arrow positioning
+        QRectF shadowRect;
+        QSize widgetSize;
+        QString labelText;
+        qreal hiResCrossfade = 1.0;
+        bool isVideoPlaying = false;
+
+        // PDF navigation arrows
+        bool showPdfArrows = false;
+        QRect pdfArrowUpRect;
+        QRect pdfArrowDownRect;
+        bool canGoUp = false;
+        bool canGoDown = false;
+        bool pdfPageLoading = false;
+        qreal spinnerAngle = 0.0;
+    };
+
+    virtual void initialize() = 0;
+    virtual void resize(int w, int h) = 0;
+
+    // Upload content image to renderer (slot 0 = current, slot 1 = crossfade old)
+    virtual void uploadContent(const QImage &image, int slot = 0) = 0;
+
+    // Upload both images for crossfade transition
+    virtual void uploadCrossfadeContent(const QImage &newImage, const QImage &oldImage) = 0;
+
+    virtual void render(const RenderState &state) = 0;
+    virtual void cleanup() = 0;
+    virtual bool isAccelerated() const = 0;
+
+    // Returns the widget used for rendering (may be the overlay itself or a child GL widget)
+    virtual QWidget *renderWidget() const = 0;
+};
+
+#endif // QUICKLOOKRENDERER_H
