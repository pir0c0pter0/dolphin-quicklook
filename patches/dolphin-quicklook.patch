+QImage QuickLookOverlay::generateVinylImage(int size)
+{
+    QImage image(size, size, QImage::Format_ARGB32_Premultiplied);
+    image.fill(Qt::transparent);
+
+    QPainter p(&image);
+    p.setRenderHint(QPainter::Antialiasing);
+
+    const qreal cx = size / 2.0;
+    const qreal cy = size / 2.0;
+    const qreal outerR = (size - 4) / 2.0;
+    const qreal labelR = outerR * 0.33;
+    const qreal holeR = outerR * 0.025;
+
+    // Main vinyl disc
+    QRadialGradient discGrad(cx, cy, outerR);
+    discGrad.setColorAt(0.0, QColor(40, 40, 40));
+    discGrad.setColorAt(0.25, QColor(25, 25, 25));
+    discGrad.setColorAt(0.5, QColor(18, 18, 18));
+    discGrad.setColorAt(0.75, QColor(28, 28, 28));
+    discGrad.setColorAt(1.0, QColor(15, 15, 15));
+
+    p.setPen(Qt::NoPen);
+    p.setBrush(discGrad);
+    p.drawEllipse(QPointF(cx, cy), outerR, outerR);
+
+    // Light reflection highlight (upper-left)
+    QRadialGradient highlight(cx - outerR * 0.3, cy - outerR * 0.3, outerR * 1.2);
+    highlight.setColorAt(0.0, QColor(255, 255, 255, 18));
+    highlight.setColorAt(0.4, QColor(255, 255, 255, 6));
+    highlight.setColorAt(1.0, QColor(0, 0, 0, 0));
+    p.setBrush(highlight);
+    p.drawEllipse(QPointF(cx, cy), outerR, outerR);
+
+    // Groove lines (concentric circles with varying brightness)
+    p.setBrush(Qt::NoBrush);
+    for (qreal r = labelR + 8; r < outerR - 4; r += 2.5) {
+        int brightness = 30 + static_cast<int>(12 * std::sin(r * 0.25));
+        int alpha = 35 + static_cast<int>(15 * std::cos(r * 0.12));
+        QPen groovePen(QColor(brightness, brightness, brightness, alpha), 0.7);
+        p.setPen(groovePen);
+        p.drawEllipse(QPointF(cx, cy), r, r);
+    }
+
+    // Edge bevel
+    QPen edgePen(QColor(55, 55, 55, 100), 1.5);
+    p.setPen(edgePen);
+    p.setBrush(Qt::NoBrush);
+    p.drawEllipse(QPointF(cx, cy), outerR, outerR);
+
+    // Green center label — conical gradient for cloudy look
+    QPainterPath labelClip;
+    labelClip.addEllipse(QPointF(cx, cy), labelR, labelR);
+    p.setClipPath(labelClip);
+
+    QConicalGradient cloudGrad(cx, cy, 45);
+    cloudGrad.setColorAt(0.0, QColor(80, 210, 50));
+    cloudGrad.setColorAt(0.15, QColor(50, 180, 30));
+    cloudGrad.setColorAt(0.35, QColor(90, 200, 60));
+    cloudGrad.setColorAt(0.5, QColor(40, 170, 25));
+    cloudGrad.setColorAt(0.7, QColor(70, 220, 45));
+    cloudGrad.setColorAt(0.85, QColor(45, 160, 30));
+    cloudGrad.setColorAt(1.0, QColor(80, 210, 50));
+
+    p.setPen(Qt::NoPen);
+    p.setBrush(cloudGrad);
+    p.drawEllipse(QPointF(cx, cy), labelR, labelR);
+
+    // Depth overlay on green center
+    QRadialGradient depthGrad(cx - labelR * 0.2, cy - labelR * 0.25, labelR * 1.1);
+    depthGrad.setColorAt(0.0, QColor(255, 255, 255, 35));
+    depthGrad.setColorAt(0.4, QColor(0, 0, 0, 0));
+    depthGrad.setColorAt(0.8, QColor(0, 0, 0, 30));
+    depthGrad.setColorAt(1.0, QColor(0, 0, 0, 50));
+    p.setBrush(depthGrad);
+    p.drawEllipse(QPointF(cx, cy), labelR, labelR);
+
+    p.setClipping(false);
+
+    // Green center edge ring
+    QPen labelEdge(QColor(35, 200, 35, 180), 2.0);
+    p.setPen(labelEdge);
+    p.setBrush(Qt::NoBrush);
+    p.drawEllipse(QPointF(cx, cy), labelR, labelR);
+
+    // Center spindle hole
+    p.setPen(Qt::NoPen);
+    p.setBrush(QColor(8, 8, 8));
+    p.drawEllipse(QPointF(cx, cy), holeR, holeR);
+    QPen holePen(QColor(60, 60, 60, 120), 0.5);
+    p.setPen(holePen);
+    p.setBrush(Qt::NoBrush);
+    p.drawEllipse(QPointF(cx, cy), holeR, holeR);
+
+    p.end();
+    return image;
+}
