+
+bool QuickLookOverlay::probeGpuAvailability()
+{
+#ifdef HAVE_OPENGL
+    QOffscreenSurface surface;
+    surface.create();
+    if (!surface.isValid()) {
+        return false;
+    }
+
+    QOpenGLContext context;
+    if (!context.create()) {
+        return false;
+    }
+
+    if (!context.makeCurrent(&surface)) {
+        return false;
+    }
+
+    const auto version = context.format().version();
+    const bool isES = context.isOpenGLES();
+    const bool sufficient = isES ? (version.first >= 2) : (version.first >= 3 || (version.first == 2 && version.second >= 1));
+
+    const char *rendererStr = reinterpret_cast<const char *>(context.functions()->glGetString(GL_RENDERER));
+    const QString renderer = rendererStr ? QString::fromLatin1(rendererStr) : QString();
+
+    const bool softwareRenderer = renderer.contains(QLatin1String("llvmpipe"), Qt::CaseInsensitive)
+        || renderer.contains(QLatin1String("softpipe"), Qt::CaseInsensitive) || renderer.contains(QLatin1String("swrast"), Qt::CaseInsensitive);
+
+    context.doneCurrent();
+    return sufficient && !softwareRenderer;
+#else
+    return false;
+#endif
+}
+
+QuickLookOverlay::QuickLookOverlay(QWidget *parent)
+    : QWidget(parent)
+    , m_animationProgress(0.0)
+    , m_active(false)
+    , m_contentType(ContentType::Image)
+#ifdef HAVE_QTMULTIMEDIA
+    , m_videoPhase(VideoPhase::Loading)
+    , m_mediaPlayer(nullptr)
+    , m_videoSink(nullptr)
+    , m_audioOutput(nullptr)
+    , m_videoLoadTimer(nullptr)
+#endif
+{
+    setFocusPolicy(Qt::StrongFocus);
+
+    // Probe GPU once (cached across instances)
+    static const bool gpuAvailable = probeGpuAvailability();
+
+#ifdef HAVE_OPENGL
+    if (gpuAvailable) {
+        m_renderer = std::make_unique<QuickLookGLRenderer>(this);
+    } else {
+        m_renderer = std::make_unique<QuickLookSWRenderer>(this);
+    }
+#else
+    Q_UNUSED(gpuAvailable)
+    m_renderer = std::make_unique<QuickLookSWRenderer>(this);
+#endif
+
+    m_renderer->initialize();
+
+    m_hiResRenderTimer = new QTimer(this);
+    m_hiResRenderTimer->setSingleShot(true);
+    connect(m_hiResRenderTimer, &QTimer::timeout, this, &QuickLookOverlay::rerenderHiRes);
+    connect(&m_renderWatcher, &QFutureWatcher<QImage>::finished, this, &QuickLookOverlay::onHiResRenderFinished);
+    connect(&m_pageRenderWatcher, &QFutureWatcher<QImage>::finished, this, &QuickLookOverlay::onPdfPageRenderFinished);
+
+    hide();
+}
+
+QuickLookOverlay::~QuickLookOverlay()
+{
+    cancelPendingRenders();
+#ifdef HAVE_QTMULTIMEDIA
+    cleanupVideo();
+#endif
+    if (m_renderer) {
+        m_renderer->cleanup();
+    }
+}
+
+void QuickLookOverlay::cancelPendingRenders()
+{
+    m_renderWatcher.cancel();
+    m_renderWatcher.waitForFinished();
+    m_renderPending = false;
+
+    m_pageRenderWatcher.cancel();
+    m_pageRenderWatcher.waitForFinished();
+    m_pageRenderPending = false;
+
+    stopPdfSpinner();
+    m_hiResRenderTimer->stop();
+}
+
+bool QuickLookOverlay::isGpuAccelerated() const
+{
+    return m_renderer && m_renderer->isAccelerated();
+}
+
+bool QuickLookOverlay::isSupportedMimeType(const QString &mimeType)
+{
+    if (mimeType.startsWith(QLatin1String("image/"))) {
+        return true;
+    }
+
+    if (mimeType == QLatin1String("application/pdf")) {
+#ifdef HAVE_POPPLER
+        return true;
+#else
+        return false;
+#endif
+    }
+
+#ifdef HAVE_QTMULTIMEDIA
+    if (mimeType.startsWith(QLatin1String("video/"))) {
+        return true;
+    }
+#endif
+
+    return false;
+}
+
+void QuickLookOverlay::uploadContentToRenderer()
+{
+    if (m_contentImage.isNull() || !m_renderer) {
+        return;
+    }
+    m_renderer->uploadContent(m_contentImage, 0);
+}
+
+void QuickLookOverlay::uploadCrossfadeToRenderer(const QImage &newImage, const QImage &oldImage)
+{
+    if (!m_renderer) {
+        return;
+    }
+    m_renderer->uploadCrossfadeContent(newImage, oldImage);
+}
+
+bool QuickLookOverlay::loadImage(const QString &filePath)
+{
+    QImageReader reader(filePath);
+    reader.setAutoTransform(true);
+
+    const QSize maxSize(3840, 2160);
+    const QSize imgSize = reader.size();
+    if (imgSize.isValid() && (imgSize.width() > maxSize.width() || imgSize.height() > maxSize.height())) {
+        QSize scaled = imgSize;
+        scaled.scale(maxSize, Qt::KeepAspectRatio);
+        reader.setScaledSize(scaled);
+    }
+
+    const QImage image = reader.read();
+    if (image.isNull()) {
+        return false;
+    }
+
+    m_contentImage = image;
+    m_pixmap = QPixmap::fromImage(image);
+    m_contentType = ContentType::Image;
+    m_imageFilePath = filePath;
+    m_imageOriginalSize = imgSize.isValid() ? imgSize : image.size();
+    m_imageRenderedWidth = m_pixmap.width();
+    m_hiResLowResImage = QImage();
+    m_hiResCrossfading = false;
+    m_statusText.clear();
+
+    uploadContentToRenderer();
+    return true;
+}
+
+bool QuickLookOverlay::loadPdf(const QString &filePath)
+{
+#ifdef HAVE_POPPLER
+    m_pdfDocument = Poppler::Document::load(filePath);
+    if (!m_pdfDocument) {
+        return false;
+    }
+
+    m_pdfDocument->setRenderHint(Poppler::Document::Antialiasing);
+    m_pdfDocument->setRenderHint(Poppler::Document::TextAntialiasing);
+    m_pdfDocument->setRenderHint(Poppler::Document::TextHinting);
+    m_pdfDocument->setRenderHint(Poppler::Document::ThinLineSolid);
+
+    m_pdfBgDocument = Poppler::Document::load(filePath);
+    if (m_pdfBgDocument) {
+        m_pdfBgDocument->setRenderHint(Poppler::Document::Antialiasing);
+        m_pdfBgDocument->setRenderHint(Poppler::Document::TextAntialiasing);
+        m_pdfBgDocument->setRenderHint(Poppler::Document::TextHinting);
+        m_pdfBgDocument->setRenderHint(Poppler::Document::ThinLineSolid);
+    }
+
+    m_pdfTotalPages = m_pdfDocument->numPages();
+    m_pdfCurrentPage = 0;
+    m_pdfFilePath = filePath;
+    m_contentType = ContentType::Pdf;
+    m_imageFilePath.clear();
+    m_pdfPageCache.clear();
+    m_pdfCacheLru.clear();
+
+    renderPdfPage(0);
+
+    if (!m_contentImage.isNull()) {
+        m_hiResRenderTimer->start(PdfPageRenderDelayMs);
+    }
+
+    return !m_contentImage.isNull();
+#else
+    Q_UNUSED(filePath)
+    return false;
+#endif
+}
+
+void QuickLookOverlay::renderPdfPage(int pageIndex)
+{
+#ifdef HAVE_POPPLER
+    if (!m_pdfDocument || pageIndex < 0 || pageIndex >= m_pdfTotalPages) {
+        return;
+    }
+
+    m_pdfCurrentPage = pageIndex;
+    m_hiResLowResImage = QImage();
+    m_hiResCrossfading = false;
+
+    const QImage cached = pdfCacheLookup(pageIndex);
+    if (!cached.isNull()) {
+        m_contentImage = cached;
+        m_pixmap = QPixmap::fromImage(cached);
+        m_pdfRenderedDpi = PdfBaseDpi;
+        updatePdfStatusText();
+        uploadContentToRenderer();
+        return;
+    }
+
+    m_pdfPage = m_pdfDocument->page(pageIndex);
+    if (!m_pdfPage) {
+        return;
+    }
+
+    const QSizeF pageSize = m_pdfPage->pageSizeF();
+    const qreal dpi = computePdfDisplayDpi(pageSize);
+    const QImage image = m_pdfPage->renderToImage(dpi, dpi);
+    if (image.isNull()) {
+        return;
+    }
+
+    m_contentImage = image;
+    m_pixmap = QPixmap::fromImage(image);
+    m_pdfRenderedDpi = dpi;
+    updatePdfStatusText();
+    uploadContentToRenderer();
+#else
+    Q_UNUSED(pageIndex)
+#endif
+}
+
+qreal QuickLookOverlay::computePdfDisplayDpi(const QSizeF &pageSizePoints) const
+{
+    if (pageSizePoints.isEmpty()) {
+        return PdfBaseDpi;
+    }
+
+    // Determine available display area in logical pixels
+    int areaW = width() - 2 * ContentPadding;
+    int areaH = height() - 2 * ContentPadding - BottomExtraSpace;
+
+    // If widget isn't sized yet, try parent
+    if (areaW <= 0 || areaH <= 0) {
+        if (parentWidget()) {
+            areaW = parentWidget()->width() - 2 * ContentPadding;
+            areaH = parentWidget()->height() - 2 * ContentPadding - BottomExtraSpace;
+        }
+        if (areaW <= 0 || areaH <= 0) {
+            return PdfBaseDpi;
+        }
+    }
+
+    // Calculate how many logical pixels the page will occupy
+    QSizeF displaySize(pageSizePoints);
+    displaySize.scale(areaW, areaH, Qt::KeepAspectRatio);
+
+    // Account for device pixel ratio so texture matches physical pixels
+    const qreal dpr = devicePixelRatioF();
+
+    // DPI = physicalPixels / inches = (logicalPixels * dpr) / (points / 72)
+    const qreal dpi = (displaySize.width() * dpr) / (pageSizePoints.width() / 72.0);
+
+    return qBound(72.0, dpi, PdfMaxDpi);
+}
+
+void QuickLookOverlay::updatePdfStatusText()
+{
+    m_statusText = (m_pdfTotalPages > 1) ? QStringLiteral(" — Page %1 of %2").arg(m_pdfCurrentPage + 1).arg(m_pdfTotalPages) : QStringLiteral(" — 1 page");
+}
+
+void QuickLookOverlay::startPdfSpinner()
+{
+    if (!m_spinnerTimer) {
+        m_spinnerTimer = new QTimer(this);
+        connect(m_spinnerTimer, &QTimer::timeout, this, [this]() {
+            m_spinnerAngle += 30.0;
+            if (m_spinnerAngle >= 360.0) {
+                m_spinnerAngle -= 360.0;
+            }
+            update();
+        });
+    }
+    m_spinnerAngle = 0.0;
+    m_spinnerTimer->start(50);
+}
+
+void QuickLookOverlay::stopPdfSpinner()
+{
+    if (m_spinnerTimer) {
+        m_spinnerTimer->stop();
+    }
+    m_pdfPageLoading = false;
+    m_spinnerAngle = 0.0;
+}
+
+void QuickLookOverlay::navigatePdfPage(int direction)
+{
+#ifdef HAVE_POPPLER
+    if (m_contentType != ContentType::Pdf || m_pdfTotalPages <= 1) {
+        return;
+    }
+
+    const int newPage = m_pdfCurrentPage + direction;
+    if (newPage < 0 || newPage >= m_pdfTotalPages) {
+        return;
+    }
+
+    if (m_pageRenderPending || m_pdfPageLoading) {
+        return;
+    }
+
+    m_hiResRenderTimer->stop();
+    resetZoom();
+
+    m_pdfCurrentPage = newPage;
+    m_pdfPage = m_pdfDocument->page(newPage);
+    m_hiResLowResImage = QImage();
+    m_hiResCrossfading = false;
+    updatePdfStatusText();
+
+    // Check cache — if cached, crossfade immediately
+    const QImage cached = pdfCacheLookup(newPage);
+    if (!cached.isNull()) {
+        m_crossfadeOldImage = m_contentImage;
+        m_contentImage = cached;
+        m_pixmap = QPixmap::fromImage(cached);
+        m_pdfRenderedDpi = PdfBaseDpi;
+
+        uploadCrossfadeToRenderer(m_contentImage, m_crossfadeOldImage);
+        m_hiResCrossfade = 0.0;
+        m_hiResCrossfading = true;
+        m_hiResFadeTimer.start();
+
+        m_hiResRenderTimer->start(PdfPageRenderDelayMs);
+        prefetchAdjacentPages();
+        update();
+        return;
+    }
+
+    // Not cached — async render with loading spinner
+    m_pdfPageLoading = true;
+    startPdfSpinner();
+    renderPdfPageAsync(newPage);
+    update();
+#else
+    Q_UNUSED(direction)
+#endif
+}
+
+void QuickLookOverlay::renderPdfPageAsync(int pageIndex)
+{
+#ifdef HAVE_POPPLER
+    if (m_pageRenderPending || m_renderPending || !m_pdfBgDocument) {
+        return;
+    }
+
+    if (m_pdfPageCache.contains(pageIndex)) {
+        return;
+    }
+
+    m_pageRenderPending = true;
+    m_pageRenderTargetPage = pageIndex;
+
+    Poppler::Document *bgDoc = m_pdfBgDocument.get();
+    const qreal dpi = computePdfDisplayDpi(m_pdfPage ? m_pdfPage->pageSizeF() : QSizeF(595, 842));
+    m_pageRenderWatcher.setFuture(QtConcurrent::run([bgDoc, pageIndex, dpi]() -> QImage {
+        auto pg = bgDoc->page(pageIndex);
+        if (!pg) {
+            return {};
+        }
+        return pg->renderToImage(dpi, dpi);
+    }));
+#else
+    Q_UNUSED(pageIndex)
+#endif
+}
+
+void QuickLookOverlay::onPdfPageRenderFinished()
+{
+    m_pageRenderPending = false;
+
+    if (!m_active || m_contentType != ContentType::Pdf) {
+        return;
+    }
+
+    if (m_pageRenderWatcher.isCanceled()) {
+        return;
+    }
+
+    const QImage image = m_pageRenderWatcher.result();
+    if (image.isNull()) {
+        return;
+    }
+
+    const int targetPage = m_pageRenderTargetPage;
+
+    pdfCacheInsert(targetPage, image);
+
+    if (targetPage == m_pdfCurrentPage) {
+        if (m_pdfPageLoading) {
+            stopPdfSpinner();
+        }
+
+        m_hiResLowResImage = m_contentImage;
+        m_crossfadeOldImage = m_contentImage;
+        m_contentImage = image;
+        m_pixmap = QPixmap::fromImage(image);
+        m_pdfRenderedDpi = PdfBaseDpi;
+
+        uploadCrossfadeToRenderer(m_contentImage, m_crossfadeOldImage);
+
+        m_hiResCrossfade = 0.0;
+        m_hiResCrossfading = true;
+        m_hiResFadeTimer.start();
+
+        m_hiResRenderTimer->start(PdfPageRenderDelayMs);
+        update();
+    }
+
+    prefetchAdjacentPages();
+}
+
+void QuickLookOverlay::prefetchAdjacentPages()
+{
+#ifdef HAVE_POPPLER
+    if (m_pageRenderPending) {
+        return;
+    }
+
+    const int next = m_pdfCurrentPage + 1;
+    const int prev = m_pdfCurrentPage - 1;
+
+    if (next < m_pdfTotalPages && !m_pdfPageCache.contains(next)) {
+        renderPdfPageAsync(next);
+    } else if (prev >= 0 && !m_pdfPageCache.contains(prev)) {
+        renderPdfPageAsync(prev);
+    }
+#endif
+}
+
+#ifdef HAVE_QTMULTIMEDIA
+void QuickLookOverlay::setupVideo(const QUrl &fileUrl)
+{
+    cleanupVideo();
+
+    m_contentType = ContentType::Video;
+    m_videoPhase = VideoPhase::Loading;
+    m_contentImage = QImage();
+    m_pixmap = QPixmap();
+    m_statusText.clear();
+
+    m_audioOutput = new QAudioOutput(this);
+    m_audioOutput->setVolume(DefaultVolume);
+
+    m_mediaPlayer = new QMediaPlayer(this);
+    m_mediaPlayer->setAudioOutput(m_audioOutput);
+
+    m_videoSink = new QVideoSink(this);
+    m_mediaPlayer->setVideoOutput(m_videoSink);
+
+    m_mediaPlayer->setSource(fileUrl);
+    m_mediaPlayer->setLoops(QMediaPlayer::Infinite);
+
+    m_videoLoadTimer = new QTimer(this);
+    m_videoLoadTimer->setSingleShot(true);
+    connect(m_videoLoadTimer, &QTimer::timeout, this, [this]() {
+        if (m_videoPhase == VideoPhase::Loading) {
+            m_active = false;
+            cleanupVideo();
+            hide();
+            Q_EMIT previewClosed();
+        }
+    });
+    m_videoLoadTimer->start(VideoLoadTimeoutMs);
+
+    connect(m_mediaPlayer, &QMediaPlayer::errorOccurred, this, [this]() {
+        m_active = false;
+        cleanupVideo();
+        hide();
+        Q_EMIT previewClosed();
+    });
+
+    connect(m_videoSink, &QVideoSink::videoFrameChanged, this, [this](const QVideoFrame &frame) {
+        QVideoFrame f = frame;
+        if (!f.isValid()) {
+            return;
+        }
+
+        const QImage image = f.toImage();
+        if (image.isNull()) {
+            return;
+        }
+
+        if (m_videoPhase == VideoPhase::Loading) {
+            if (m_videoLoadTimer) {
+                m_videoLoadTimer->stop();
+                m_videoLoadTimer->deleteLater();
+                m_videoLoadTimer = nullptr;
+            }
+            m_contentImage = image;
+            m_pixmap = QPixmap::fromImage(image);
+            m_videoPhase = VideoPhase::Animating;
+            m_mediaPlayer->pause();
+
+            uploadContentToRenderer();
+
+            if (!parentWidget()) {
+                return;
+            }
+            move(0, 0);
+            resize(parentWidget()->size());
+            show();
+            raise();
+            setFocus();
+            startShowAnimation();
+            return;
+        }
+
+        if (m_videoPhase == VideoPhase::Playing) {
+            m_contentImage = image;
+            m_pixmap = QPixmap::fromImage(image);
+            uploadContentToRenderer();
+            update();
+        }
+    });
+
+    m_mediaPlayer->play();
+}
+
+void QuickLookOverlay::cleanupVideo()
+{
+    if (m_videoLoadTimer) {
+        m_videoLoadTimer->stop();
+        m_videoLoadTimer->deleteLater();
+        m_videoLoadTimer = nullptr;
+    }
+    if (m_mediaPlayer) {
+        m_mediaPlayer->stop();
+        m_mediaPlayer->deleteLater();
+        m_mediaPlayer = nullptr;
+    }
+    if (m_videoSink) {
+        m_videoSink->deleteLater();
+        m_videoSink = nullptr;
+    }
+    if (m_audioOutput) {
+        m_audioOutput->deleteLater();
+        m_audioOutput = nullptr;
+    }
+}
+#endif
+
+void QuickLookOverlay::pdfCacheInsert(int pageIndex, const QImage &image)
+{
+    if (m_pdfPageCache.contains(pageIndex)) {
+        m_pdfCacheLru.removeOne(pageIndex);
+        m_pdfCacheLru.prepend(pageIndex);
+        m_pdfPageCache[pageIndex] = image;
+        return;
+    }
+
+    while (m_pdfCacheLru.size() >= PdfCacheMaxPages) {
+        const int evicted = m_pdfCacheLru.takeLast();
+        m_pdfPageCache.remove(evicted);
+    }
+
+    m_pdfPageCache.insert(pageIndex, image);
+    m_pdfCacheLru.prepend(pageIndex);
+}
+
+QImage QuickLookOverlay::pdfCacheLookup(int pageIndex)
+{
+    if (!m_pdfPageCache.contains(pageIndex)) {
+        return {};
+    }
+
+    m_pdfCacheLru.removeOne(pageIndex);
+    m_pdfCacheLru.prepend(pageIndex);
+
+    return m_pdfPageCache.value(pageIndex);
+}
+
+bool QuickLookOverlay::showPreview(const QUrl &fileUrl)
+{
+    if (!fileUrl.isLocalFile()) {
+        return false;
+    }
+
+    // Cancel any in-flight async renders before switching content
+    cancelPendingRenders();
+
+    // If a hide animation was in progress, run its cleanup now
+    if (m_animating && !m_animForward) {
+        m_animating = false;
+        m_contentImage = QImage();
+        m_pixmap = QPixmap();
+#ifdef HAVE_POPPLER
+        m_pdfPage.reset();
+        m_pdfDocument.reset();
+        m_pdfBgDocument.reset();
+        m_pdfPageCache.clear();
+        m_pdfCacheLru.clear();
+#endif
+#ifdef HAVE_QTMULTIMEDIA
+        cleanupVideo();
+#endif
+    } else {
+        m_animating = false;
+    }
+
+    const QString filePath = fileUrl.toLocalFile();
+    QMimeDatabase mimeDb;
+    const QString mimeType = mimeDb.mimeTypeForFile(filePath).name();
+
+    bool loaded = false;
+
+    if (mimeType.startsWith(QLatin1String("image/"))) {
+        loaded = loadImage(filePath);
+    } else if (mimeType == QLatin1String("application/pdf")) {
+        loaded = loadPdf(filePath);
+    }
+#ifdef HAVE_QTMULTIMEDIA
+    else if (mimeType.startsWith(QLatin1String("video/"))) {
+        m_currentUrl = fileUrl;
+        m_active = true;
+        resetZoom();
+        setupVideo(fileUrl);
+        return true;
+    }
+#endif
+
+    if (!loaded) {
+        return false;
+    }
+
+    m_currentUrl = fileUrl;
+    m_active = true;
+    resetZoom();
+
+    if (!parentWidget()) {
+        return false;
+    }
+    move(0, 0);
+    resize(parentWidget()->size());
+
+    // Resize GL widget if using GPU renderer
+    if (m_renderer) {
+        m_renderer->resize(width(), height());
+    }
+
+    show();
+    raise();
+    setFocus();
+
+    // Re-upload content after show() so that the GL context is guaranteed
+    // to be initialised (initializeGL runs on first show).
+    uploadContentToRenderer();
+
+    startShowAnimation();
+    return true;
+}
+
+void QuickLookOverlay::hidePreview()
+{
+    if (!m_active) {
+        return;
+    }
+
+#ifdef HAVE_QTMULTIMEDIA
+    if (m_contentType == ContentType::Video) {
+        if (m_mediaPlayer) {
+            m_mediaPlayer->pause();
+        }
+        m_videoPhase = VideoPhase::Closing;
+    }
+#endif
+
+    startHideAnimation();
+}
+
+bool QuickLookOverlay::isPreviewActive() const
+{
+    return m_active;
+}
+
+qreal QuickLookOverlay::animationProgress() const
+{
+    return m_animationProgress;
+}
+
+void QuickLookOverlay::setAnimationProgress(qreal progress)
+{
+    m_animationProgress = progress;
+    update();
+}
+
+void QuickLookOverlay::advanceAnimation()
+{
+    if (!m_animating) {
+        return;
+    }
+
+    const qreal elapsed = static_cast<qreal>(m_animTimer.elapsed());
+    const qreal duration = qMax(1.0, static_cast<qreal>(m_animDuration));
+    const qreal t = qBound(0.0, elapsed / duration, 1.0);
+    const qreal easedT = m_easingCurve.valueForProgress(t);
+    m_animationProgress = m_animStartValue + (m_animEndValue - m_animStartValue) * easedT;
+
+    if (t >= 1.0) {
+        m_animating = false;
+        onAnimationFinished();
+    }
+}
+
+void QuickLookOverlay::onAnimationFinished()
+{
+    if (m_animForward) {
+#ifdef HAVE_QTMULTIMEDIA
+        if (m_contentType == ContentType::Video && m_videoPhase == VideoPhase::Animating && m_mediaPlayer) {
+            m_videoPhase = VideoPhase::Playing;
+            m_mediaPlayer->play();
+        }
+#endif
+    } else {
+        m_active = false;
+
+        // Cancel async renders before destroying documents they reference
+        cancelPendingRenders();
+
+        m_contentImage = QImage();
+        m_pixmap = QPixmap();
+#ifdef HAVE_POPPLER
+        m_pdfPage.reset();
+        m_pdfDocument.reset();
+        m_pdfBgDocument.reset();
+        m_pdfPageCache.clear();
+        m_pdfCacheLru.clear();
+#endif
+#ifdef HAVE_QTMULTIMEDIA
+        cleanupVideo();
+#endif
+        hide();
+        Q_EMIT previewClosed();
+    }
+}
+
+void QuickLookOverlay::advanceZoomAnimation()
+{
+    if (!m_zoomAnimating) {
+        return;
+    }
+
+    const qreal elapsed = static_cast<qreal>(m_zoomAnimTimer.elapsed());
+    const qreal duration = qMax(1.0, static_cast<qreal>(m_zoomAnimDuration));
+    const qreal t = qBound(0.0, elapsed / duration, 1.0);
+    const qreal easedT = m_easingCurve.valueForProgress(t);
+
+    m_zoomFactor = m_zoomAnimStartFactor + (1.0 - m_zoomAnimStartFactor) * easedT;
+    m_panOffset = m_zoomAnimStartPan * (1.0 - easedT);
+
+    if (t >= 1.0) {
+        m_zoomAnimating = false;
+        m_zoomFactor = 1.0;
+        m_panOffset = QPointF(0, 0);
+        setCursor(Qt::ArrowCursor);
+        scheduleHiResRerender();
+    }
+}
+
+void QuickLookOverlay::animateZoomReset()
+{
+    m_zoomAnimStartFactor = m_zoomFactor;
+    m_zoomAnimStartPan = m_panOffset;
+    m_zoomAnimating = true;
+    m_zoomAnimTimer.start();
+    m_dragging = false;
+    update();
+}
+
+void QuickLookOverlay::scheduleHiResRerender()
+{
+    if (m_contentType == ContentType::Pdf) {
+#ifdef HAVE_POPPLER
+        if (!m_pdfPage) {
+            return;
+        }
+        const qreal baseDpi = computePdfDisplayDpi(m_pdfPage->pageSizeF());
+        const qreal targetDpi = qBound(baseDpi, baseDpi * m_zoomFactor, PdfMaxDpi);
+        const qreal ratio = targetDpi / m_pdfRenderedDpi;
+        if (ratio > 0.85 && ratio < 1.15) {
+            return;
+        }
+        m_hiResRenderTimer->start(PdfRerenderDelayMs);
+#endif
+    } else if (m_contentType == ContentType::Image && !m_imageFilePath.isEmpty()) {
+        if (!m_imageOriginalSize.isValid() || m_pixmap.isNull()) {
+            return;
+        }
+
+        const QRectF base = baseContentRect();
+        const int targetWidth = qBound(static_cast<int>(base.width()), static_cast<int>(base.width() * m_zoomFactor), m_imageOriginalSize.width());
+        const qreal ratio = static_cast<qreal>(targetWidth) / m_imageRenderedWidth;
+        if (ratio > 0.85 && ratio < 1.15) {
+            return;
+        }
+
+        m_hiResRenderTimer->start(PdfRerenderDelayMs);
+    }
+}
+
+void QuickLookOverlay::rerenderHiRes()
+{
+    if (m_renderPending || m_pageRenderPending) {
+        m_hiResRenderTimer->start(PdfRerenderDelayMs);
+        return;
+    }
+
+    if (m_contentType == ContentType::Pdf) {
+#ifdef HAVE_POPPLER
+        if (!m_pdfPage) {
+            return;
+        }
+
+        const qreal baseDpi = computePdfDisplayDpi(m_pdfPage->pageSizeF());
+
+        if (m_pdfRenderedDpi < baseDpi && qFuzzyCompare(m_zoomFactor, 1.0)) {
+            renderPdfPageAsync(m_pdfCurrentPage);
+            return;
+        }
+
+        const qreal targetDpi = qBound(baseDpi, baseDpi * m_zoomFactor, PdfMaxDpi);
+        const qreal ratio = targetDpi / m_pdfRenderedDpi;
+        if (ratio > 0.85 && ratio < 1.15) {
+            return;
+        }
+
+        m_renderTargetDpi = targetDpi;
+        m_renderPending = true;
+        m_renderPageIndex = m_pdfCurrentPage;
+
+        const QString filePath = m_pdfFilePath;
+        const qreal dpi = targetDpi;
+        const int pageIndex = m_pdfCurrentPage;
+
+        if (m_pdfBgDocument) {
+            Poppler::Document *bgDoc = m_pdfBgDocument.get();
+            m_renderWatcher.setFuture(QtConcurrent::run([bgDoc, dpi, pageIndex]() -> QImage {
+                auto pg = bgDoc->page(pageIndex);
+                if (!pg) {
+                    return {};
+                }
+                return pg->renderToImage(dpi, dpi);
+            }));
+        } else {
+            m_renderWatcher.setFuture(QtConcurrent::run([filePath, dpi, pageIndex]() -> QImage {
+                auto doc = Poppler::Document::load(filePath);
+                if (!doc) {
+                    return {};
+                }
+                doc->setRenderHint(Poppler::Document::Antialiasing);
+                doc->setRenderHint(Poppler::Document::TextAntialiasing);
+                doc->setRenderHint(Poppler::Document::TextHinting);
+                doc->setRenderHint(Poppler::Document::ThinLineSolid);
+                auto pg = doc->page(pageIndex);
+                if (!pg) {
+                    return {};
+                }
+                return pg->renderToImage(dpi, dpi);
+            }));
+        }
+#endif
+    } else if (m_contentType == ContentType::Image && !m_imageFilePath.isEmpty()) {
+        const QRectF base = baseContentRect();
+        const int targetWidth = qBound(static_cast<int>(base.width()), static_cast<int>(base.width() * m_zoomFactor), m_imageOriginalSize.width());
+        const qreal ratio = static_cast<qreal>(targetWidth) / m_imageRenderedWidth;
+        if (ratio > 0.85 && ratio < 1.15) {
+            return;
+        }
+
+        m_renderPending = true;
+        m_renderImageFilePath = m_imageFilePath;
+
+        const QString filePath = m_imageFilePath;
+        const QSize origSize = m_imageOriginalSize;
+        if (origSize.width() <= 0 || origSize.height() <= 0) {
+            m_renderPending = false;
+            return;
+        }
+        const int tw = targetWidth;
+        m_renderWatcher.setFuture(QtConcurrent::run([filePath, origSize, tw]() -> QImage {
+            QImageReader reader(filePath);
+            reader.setAutoTransform(true);
+
+            QSize scaledSize = origSize;
+            scaledSize.scale(tw, tw * origSize.height() / origSize.width(), Qt::KeepAspectRatio);
+            reader.setScaledSize(scaledSize);
+
+            return reader.read();
+        }));
+    }
+}
+
+void QuickLookOverlay::onHiResRenderFinished()
+{
+    m_renderPending = false;
+
+    if (!m_active) {
+        return;
+    }
+
+    if (m_renderWatcher.isCanceled()) {
+        return;
+    }
+
+    if (m_contentType == ContentType::Pdf && m_renderPageIndex != m_pdfCurrentPage) {
+        return;
+    }
+
+    if (m_contentType == ContentType::Image && m_renderImageFilePath != m_imageFilePath) {
+        return;
+    }
+
+    const QImage image = m_renderWatcher.result();
+    if (image.isNull()) {
+        return;
+    }
+
+    m_hiResLowResImage = m_contentImage;
+    m_crossfadeOldImage = m_contentImage;
+    m_contentImage = image;
+    m_pixmap = QPixmap::fromImage(image);
+
+    if (m_contentType == ContentType::Pdf) {
+        m_pdfRenderedDpi = m_renderTargetDpi;
+    } else if (m_contentType == ContentType::Image) {
+        m_imageRenderedWidth = m_pixmap.width();
+    }
+
+    uploadCrossfadeToRenderer(m_contentImage, m_crossfadeOldImage);
+
+    m_hiResCrossfade = 0.0;
+    m_hiResCrossfading = true;
+    m_hiResFadeTimer.start();
+    update();
+}
+
+void QuickLookOverlay::paintEvent(QPaintEvent *event)
+{
+    Q_UNUSED(event)
+
+    advanceAnimation();
+    advanceZoomAnimation();
+
+    // Update crossfade progress
+    if (m_hiResCrossfading) {
+        const qreal elapsed = static_cast<qreal>(m_hiResFadeTimer.elapsed());
+        m_hiResCrossfade = qBound(0.0, elapsed / PdfCrossfadeDurationMs, 1.0);
+        if (m_hiResCrossfade >= 1.0) {
+            m_hiResCrossfading = false;
+            m_hiResLowResImage = QImage();
+            m_crossfadeOldImage = QImage();
+        }
+    }
+
+    if (m_contentImage.isNull()) {
+        if (m_animating || m_zoomAnimating) {
+            update();
+        }
+        return;
+    }
+
+    // Build render state
+    QuickLookRenderer::RenderState state;
+    state.animationProgress = m_animationProgress;
+    state.zoomFactor = m_zoomFactor;
+    state.panOffset = m_panOffset;
+    state.baseContentRect = baseContentRect();
+    state.widgetSize = size();
+    state.labelText = m_currentUrl.fileName() + m_statusText;
+    state.hiResCrossfade = m_hiResCrossfading ? m_hiResCrossfade : 1.0;
+    state.isVideoPlaying = false;
+
+#ifdef HAVE_QTMULTIMEDIA
+    state.isVideoPlaying = (m_contentType == ContentType::Video && m_videoPhase == VideoPhase::Playing);
+#endif
+
+    // Compute drawRect with scale animation
+    const QPointF center = state.baseContentRect.center();
+    const qreal scale = state.isVideoPlaying ? 1.0 : (0.3 + 0.7 * m_animationProgress);
+    const qreal w = state.baseContentRect.width() * scale * m_zoomFactor;
+    const qreal h = state.baseContentRect.height() * scale * m_zoomFactor;
+    const qreal cx = center.x() + m_panOffset.x();
+    const qreal cy = center.y() + m_panOffset.y();
+    state.drawRect = QRectF(cx - w / 2.0, cy - h / 2.0, w, h);
+    state.anchorRect = QRectF(center.x() - w / 2.0, center.y() - h / 2.0, w, h);
+    state.shadowRect = state.drawRect.adjusted(ShadowOffset * m_animationProgress,
+                                               ShadowOffset * m_animationProgress,
+                                               ShadowOffset * m_animationProgress,
+                                               ShadowOffset * m_animationProgress);
+
+    // PDF arrows — anchored to baseContentRect so they don't move with drag
+    if (m_contentType == ContentType::Pdf && m_pdfTotalPages > 1 && m_animationProgress > 0.5) {
+        const int arrowSize = 36;
+        const int arrowMargin = 16;
+        const int arrowX = state.anchorRect.right() + arrowMargin;
+        const int centerY = state.anchorRect.center().y();
+
+        state.showPdfArrows = true;
+        state.pdfArrowUpRect = QRect(arrowX, centerY - arrowSize - 4, arrowSize, arrowSize);
+        state.pdfArrowDownRect = QRect(arrowX, centerY + 4, arrowSize, arrowSize);
+        state.canGoUp = m_pdfCurrentPage > 0 && !m_pdfPageLoading;
+        state.canGoDown = m_pdfCurrentPage < m_pdfTotalPages - 1 && !m_pdfPageLoading;
+        state.pdfPageLoading = m_pdfPageLoading;
+        state.spinnerAngle = m_spinnerAngle;
+
+        m_pdfArrowUpRect = state.pdfArrowUpRect;
+        m_pdfArrowDownRect = state.pdfArrowDownRect;
+    } else {
+        state.showPdfArrows = false;
+        m_pdfArrowUpRect = QRect();
+        m_pdfArrowDownRect = QRect();
+    }
+
+    m_renderer->render(state);
+
+    if (m_animating || m_zoomAnimating || m_hiResCrossfading) {
+        update();
+    }
+}
+
+void QuickLookOverlay::mouseDoubleClickEvent(QMouseEvent *event)
+{
+    Q_UNUSED(event)
+    hidePreview();
+}
+
+void QuickLookOverlay::mousePressEvent(QMouseEvent *event)
+{
+    if (event->button() == Qt::LeftButton && m_contentType == ContentType::Pdf && m_pdfTotalPages > 1 && !m_pdfPageLoading) {
+        const QPoint pos = event->pos();
+        if (m_pdfArrowUpRect.contains(pos) && m_pdfCurrentPage > 0) {
+            navigatePdfPage(-1);
+            event->accept();
+            return;
+        }
+        if (m_pdfArrowDownRect.contains(pos) && m_pdfCurrentPage < m_pdfTotalPages - 1) {
+            navigatePdfPage(1);
+            event->accept();
+            return;
+        }
+    }
+
+    if (event->button() == Qt::RightButton && m_zoomFactor > ZoomMin) {
+        animateZoomReset();
+        event->accept();
+        return;
+    }
+    if (event->button() == Qt::LeftButton && m_zoomFactor > ZoomMin) {
+        m_dragging = true;
+        m_lastMousePos = event->position();
+        setCursor(Qt::ClosedHandCursor);
+        event->accept();
+        return;
+    }
+    QWidget::mousePressEvent(event);
+}
+
+void QuickLookOverlay::mouseMoveEvent(QMouseEvent *event)
+{
+    if (m_dragging) {
+        const QPointF delta = event->position() - m_lastMousePos;
+        m_panOffset += QPointF(delta.x(), -delta.y());
+        m_lastMousePos = event->position();
+        update();
+        event->accept();
+        return;
+    }
+    QWidget::mouseMoveEvent(event);
+}
+
+void QuickLookOverlay::mouseReleaseEvent(QMouseEvent *event)
+{
+    if (event->button() == Qt::LeftButton && m_dragging) {
+        m_dragging = false;
+        setCursor(m_zoomFactor > ZoomMin ? Qt::OpenHandCursor : Qt::ArrowCursor);
+        event->accept();
+        return;
+    }
+    QWidget::mouseReleaseEvent(event);
+}
+
+void QuickLookOverlay::wheelEvent(QWheelEvent *event)
+{
+    if (!m_active || m_animating || m_zoomAnimating) {
+        event->ignore();
+        return;
+    }
+
+    const QRect contentArea = scaledContentRect();
+    const QPointF cursorPos = event->position();
+    if (!contentArea.contains(cursorPos.toPoint())) {
+        event->accept();
+        return;
+    }
+
+    const qreal oldZoom = m_zoomFactor;
+    const qreal delta = event->angleDelta().y() > 0 ? ZoomStep : -ZoomStep;
+    m_zoomFactor = qBound(ZoomMin, m_zoomFactor + delta * m_zoomFactor, ZoomMax);
+
+    if (qFuzzyCompare(m_zoomFactor, oldZoom)) {
+        event->accept();
+        return;
+    }
+
+    const QRectF base = baseContentRect();
+    const QPointF baseCenter = base.center();
+    const qreal ratio = m_zoomFactor / oldZoom;
+    m_panOffset = (1.0 - ratio) * (cursorPos - baseCenter) + ratio * m_panOffset;
+
+    if (qFuzzyCompare(m_zoomFactor, ZoomMin)) {
+        m_panOffset = QPointF(0, 0);
+        setCursor(Qt::ArrowCursor);
+    } else {
+        setCursor(Qt::OpenHandCursor);
+    }
+
+    scheduleHiResRerender();
+
+    update();
+    event->accept();
+}
+
+void QuickLookOverlay::keyPressEvent(QKeyEvent *event)
+{
+    if (event->key() == Qt::Key_Escape || event->key() == Qt::Key_Space) {
+        hidePreview();
+        event->accept();
+        return;
+    }
+
+    if (m_contentType == ContentType::Pdf && m_pdfTotalPages > 1) {
+        if (event->key() == Qt::Key_Up || event->key() == Qt::Key_PageUp) {
+            navigatePdfPage(-1);
+            event->accept();
+            return;
+        }
+        if (event->key() == Qt::Key_Down || event->key() == Qt::Key_PageDown) {
+            navigatePdfPage(1);
+            event->accept();
+            return;
+        }
+    }
+
+    QWidget::keyPressEvent(event);
+}
+
+void QuickLookOverlay::resizeEvent(QResizeEvent *event)
+{
+    QWidget::resizeEvent(event);
+    if (m_renderer) {
+        m_renderer->resize(width(), height());
+    }
+    update();
+}
+
+void QuickLookOverlay::startShowAnimation()
+{
+    m_animStartValue = m_animationProgress;
+    m_animEndValue = 1.0;
+    m_animForward = true;
+    m_animating = true;
+    m_animTimer.start();
+    update();
+}
+
+void QuickLookOverlay::startHideAnimation()
+{
+    m_animStartValue = m_animationProgress;
+    m_animEndValue = 0.0;
+    m_animForward = false;
+    m_animating = true;
+    m_animTimer.start();
+    update();
+}
+
+void QuickLookOverlay::resetZoom()
+{
+    m_zoomFactor = 1.0;
+    m_panOffset = QPointF(0, 0);
+    m_dragging = false;
+    setCursor(Qt::ArrowCursor);
+}
+
+QRectF QuickLookOverlay::baseContentRect() const
+{
+    const int maxW = width() - 2 * ContentPadding;
+    const int maxH = height() - 2 * ContentPadding - BottomExtraSpace;
+
+    QSize contentSize;
+    if (!m_pixmap.isNull()) {
+        contentSize = m_pixmap.size();
+    } else if (!m_contentImage.isNull()) {
+        contentSize = m_contentImage.size();
+    } else {
+        return {};
+    }
+
+    contentSize.scale(maxW, maxH, Qt::KeepAspectRatio);
+
+    const qreal x = (width() - contentSize.width()) / 2.0;
+    const qreal y = (height() - contentSize.height()) / 2.0 - ContentVerticalShift;
+
+    return {x, y, static_cast<qreal>(contentSize.width()), static_cast<qreal>(contentSize.height())};
+}
+
+QRect QuickLookOverlay::scaledContentRect() const
+{
+    const QRectF base = baseContentRect();
+    if (base.isEmpty()) {
+        return {};
+    }
+
+    const qreal w = base.width() * m_zoomFactor;
+    const qreal h = base.height() * m_zoomFactor;
+    const qreal cx = base.center().x() + m_panOffset.x();
+    const qreal cy = base.center().y() + m_panOffset.y();
+
+    return QRectF(cx - w / 2.0, cy - h / 2.0, w, h).toRect();
+}
