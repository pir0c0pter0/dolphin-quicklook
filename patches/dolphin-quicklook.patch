+    void navigatePdfPage(int direction);
+    void renderPdfPage(int pageIndex);
+    void renderPdfPageAsync(int pageIndex);
+    void onPdfPageRenderFinished();
+    void prefetchAdjacentPages();
+    void updatePdfStatusText();
+    void startPdfSpinner();
+    void stopPdfSpinner();
+    qreal computePdfDisplayDpi(const QSizeF &pageSizePoints) const;
+
+#ifdef HAVE_QTMULTIMEDIA
+    void setupVideo(const QUrl &fileUrl);
+    void cleanupVideo();
+#endif
+
+    void advanceAnimation();
+    void advanceZoomAnimation();
+    void onAnimationFinished();
+    QRectF baseContentRect() const;
+    void resetZoom();
+    void animateZoomReset();
+    void cancelPendingRenders();
+    void scheduleHiResRerender();
+    void rerenderHiRes();
+    void onHiResRenderFinished();
+
+    // Upload current content to the GPU/SW renderer
+    void uploadContentToRenderer();
+    void uploadCrossfadeToRenderer(const QImage &newImage, const QImage &oldImage);
+
+    // Renderer (GPU or CPU fallback)
+    std::unique_ptr<QuickLookRenderer> m_renderer;
+
+    QImage m_contentImage;
+    QImage m_crossfadeOldImage;
+    QPixmap m_pixmap; // kept for SW path compatibility and size calculations
+    QUrl m_currentUrl;
+    qreal m_animationProgress;
+    bool m_active;
+    ContentType m_contentType;
+    QString m_statusText;
+
+    // PDF page navigation
+    int m_pdfCurrentPage = 0;
+    int m_pdfTotalPages = 0;
+    QRect m_pdfArrowUpRect;
+    QRect m_pdfArrowDownRect;
+
+    // PDF page cache (LRU, keyed by page index)
+    static constexpr int PdfCacheMaxPages = 5;
+    QHash<int, QImage> m_pdfPageCache;
+    QList<int> m_pdfCacheLru;
+    void pdfCacheInsert(int pageIndex, const QImage &image);
+    QImage pdfCacheLookup(int pageIndex);
+
+    // Progressive rendering (PDF + Image)
+    QString m_pdfFilePath;
+    QString m_imageFilePath;
+    QSize m_imageOriginalSize;
+    QTimer *m_hiResRenderTimer = nullptr;
+    qreal m_pdfRenderedDpi = 0.0;
+#ifdef HAVE_POPPLER
