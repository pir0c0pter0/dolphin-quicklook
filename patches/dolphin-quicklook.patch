+#ifndef QUICKLOOKOVERLAY_H
+#define QUICKLOOKOVERLAY_H
+
+#include <QWidget>
+#include <QUrl>
+#include <QEasingCurve>
+#include <QElapsedTimer>
+#include <QPointF>
+
+#include <memory>
+#include <QFutureWatcher>
+
+class QLabel;
+class QTimer;
+
+#ifdef HAVE_POPPLER
+namespace Poppler {
+class Document;
+class Page;
+}
+#endif
+
+#ifdef HAVE_QTMULTIMEDIA
+class QMediaPlayer;
+class QVideoSink;
+class QAudioOutput;
+#endif
+
+class QuickLookOverlay : public QWidget
+{
+    Q_OBJECT
+    Q_PROPERTY(qreal animationProgress READ animationProgress WRITE setAnimationProgress)
+
+public:
+    explicit QuickLookOverlay(QWidget *parent = nullptr);
+    ~QuickLookOverlay() override;
+
+    void showPreview(const QUrl &fileUrl);
+    void hidePreview();
+    bool isPreviewActive() const;
+    static bool isSupportedMimeType(const QString &mimeType);
+
+    qreal animationProgress() const;
+    void setAnimationProgress(qreal progress);
+
+Q_SIGNALS:
+    void previewClosed();
+
+protected:
+    void paintEvent(QPaintEvent *event) override;
+    void mouseDoubleClickEvent(QMouseEvent *event) override;
+    void mousePressEvent(QMouseEvent *event) override;
+    void mouseMoveEvent(QMouseEvent *event) override;
+    void mouseReleaseEvent(QMouseEvent *event) override;
+    void wheelEvent(QWheelEvent *event) override;
+    void keyPressEvent(QKeyEvent *event) override;
+    void resizeEvent(QResizeEvent *event) override;
+
+private:
+    enum class ContentType {
+        Image,
+        Pdf,
+        Video,
+    };
+
+#ifdef HAVE_QTMULTIMEDIA
+    enum class VideoPhase {
+        Loading,
+        Animating,
+        Playing,
+        Closing,
+    };
+#endif
+
+    void startShowAnimation();
+    void startHideAnimation();
+    QRect scaledContentRect() const;
+
+    bool loadImage(const QString &filePath);
+    bool loadPdf(const QString &filePath);
+
+#ifdef HAVE_QTMULTIMEDIA
+    void setupVideo(const QUrl &fileUrl);
+    void cleanupVideo();
+#endif
+
+    void advanceAnimation();
+    void advanceZoomAnimation();
+    void onAnimationFinished();
+    QRectF baseContentRect() const;
+    void resetZoom();
+    void animateZoomReset();
+    void scheduleHiResRerender();
+    void rerenderHiRes();
+    void onHiResRenderFinished();
+
+    QPixmap m_pixmap;
+    QUrl m_currentUrl;
+    qreal m_animationProgress;
+    bool m_active;
+    ContentType m_contentType;
+    QString m_statusText;
+
+    // Progressive rendering (PDF + Image)
+    QString m_pdfFilePath;
+    QString m_imageFilePath;
+    QSize m_imageOriginalSize;
+    QTimer *m_pdfRenderTimer = nullptr;
+    qreal m_pdfRenderedDpi = 0.0;
+#ifdef HAVE_POPPLER
+    std::unique_ptr<Poppler::Document> m_pdfDocument;
+    std::unique_ptr<Poppler::Page> m_pdfPage;
+#endif
+    QPixmap m_hiResLowResPixmap;
+    qreal m_hiResCrossfade = 1.0;
+    bool m_hiResCrossfading = false;
+    QElapsedTimer m_hiResFadeTimer;
+    int m_imageRenderedWidth = 0;
+    QFutureWatcher<QImage> m_renderWatcher;
+    qreal m_renderTargetDpi = 0.0;
+    bool m_renderPending = false;
+
+    // Zoom & pan
+    qreal m_zoomFactor = 1.0;
+    QPointF m_panOffset;
+    bool m_dragging = false;
+    QPointF m_lastMousePos;
+
+    // Zoom reset animation
+    bool m_zoomAnimating = false;
+    QElapsedTimer m_zoomAnimTimer;
+    qreal m_zoomAnimStartFactor = 1.0;
+    QPointF m_zoomAnimStartPan;
+    int m_zoomAnimDuration = 200;
+
+    // Frame-driven animation (syncs with monitor refresh rate)
+    QElapsedTimer m_animTimer;
+    QEasingCurve m_easingCurve{QEasingCurve::OutCubic};
+    int m_animDuration = 250;
+    bool m_animating = false;
+    bool m_animForward = true;
+    qreal m_animStartValue = 0.0;
+    qreal m_animEndValue = 1.0;
+
+#ifdef HAVE_QTMULTIMEDIA
+    // Video playback — rendered via QVideoSink + QPainter (no QVideoWidget)
+    VideoPhase m_videoPhase;
+    QMediaPlayer *m_mediaPlayer;
+    QVideoSink *m_videoSink;
+    QAudioOutput *m_audioOutput;
+    QTimer *m_videoLoadTimer;
+#endif
+};
+
+#endif // QUICKLOOKOVERLAY_H
