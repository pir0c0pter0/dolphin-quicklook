+#ifdef HAVE_POPPLER
+#include <poppler-qt6.h>
+#endif
+
+QuickLookOverlay::QuickLookOverlay(QWidget *parent)
+    : QWidget(parent)
+    , m_animationProgress(0.0)
+    , m_active(false)
+    , m_contentType(ContentType::Image)
+#ifdef HAVE_QTMULTIMEDIA
+    , m_videoPhase(VideoPhase::Loading)
+    , m_mediaPlayer(nullptr)
+    , m_videoSink(nullptr)
+    , m_audioOutput(nullptr)
+    , m_videoLoadTimer(nullptr)
+#endif
+{
+    setFocusPolicy(Qt::StrongFocus);
+
+    m_pdfRenderTimer = new QTimer(this);
+    m_pdfRenderTimer->setSingleShot(true);
+    connect(m_pdfRenderTimer, &QTimer::timeout, this, &QuickLookOverlay::rerenderHiRes);
+    connect(&m_renderWatcher, &QFutureWatcher<QImage>::finished, this, &QuickLookOverlay::onHiResRenderFinished);
+    connect(&m_pageRenderWatcher, &QFutureWatcher<QImage>::finished, this, &QuickLookOverlay::onPdfPageRenderFinished);
+
+    hide();
+}
+
+QuickLookOverlay::~QuickLookOverlay()
+{
+    m_renderWatcher.cancel();
+    m_renderWatcher.waitForFinished();
+    m_pageRenderWatcher.cancel();
+    m_pageRenderWatcher.waitForFinished();
+#ifdef HAVE_QTMULTIMEDIA
+    cleanupVideo();
+#endif
+}
+
+bool QuickLookOverlay::isSupportedMimeType(const QString &mimeType)
+{
+    if (mimeType.startsWith(QLatin1String("image/"))) {
+        return true;
+    }
+
+    if (mimeType == QLatin1String("application/pdf")) {
+#ifdef HAVE_POPPLER
+        return true;
+#else
+        return false;
+#endif
+    }
+
+#ifdef HAVE_QTMULTIMEDIA
+    if (mimeType.startsWith(QLatin1String("video/"))) {
+        return true;
+    }
+#endif
+
+    return false;
+}
+
+bool QuickLookOverlay::loadImage(const QString &filePath)
+{
+    QImageReader reader(filePath);
+    reader.setAutoTransform(true);
+
+    // Cap decoded size to 4K to prevent OOM on very large images
+    const QSize maxSize(3840, 2160);
+    const QSize imgSize = reader.size();
+    if (imgSize.isValid() && (imgSize.width() > maxSize.width() || imgSize.height() > maxSize.height())) {
+        QSize scaled = imgSize;
+        scaled.scale(maxSize, Qt::KeepAspectRatio);
+        reader.setScaledSize(scaled);
+    }
+
+    const QImage image = reader.read();
+    if (image.isNull()) {
+        return false;
+    }
+    m_pixmap = QPixmap::fromImage(image);
+    m_contentType = ContentType::Image;
+    m_imageFilePath = filePath;
+    m_imageOriginalSize = imgSize.isValid() ? imgSize : image.size();
+    m_imageRenderedWidth = m_pixmap.width();
+    m_hiResLowResPixmap = QPixmap();
+    m_hiResCrossfading = false;
+    m_statusText.clear();
+    return true;
+}
+
+bool QuickLookOverlay::loadPdf(const QString &filePath)
+{
+#ifdef HAVE_POPPLER
+    m_pdfDocument = Poppler::Document::load(filePath);
+    if (!m_pdfDocument) {
+        return false;
+    }
+
+    m_pdfDocument->setRenderHint(Poppler::Document::Antialiasing);
+    m_pdfDocument->setRenderHint(Poppler::Document::TextAntialiasing);
+
+    // Pre-load a persistent background document for async renders
+    // (avoids reloading large files from disk on every hi-res/page render)
+    m_pdfBgDocument = Poppler::Document::load(filePath);
+    if (m_pdfBgDocument) {
+        m_pdfBgDocument->setRenderHint(Poppler::Document::Antialiasing);
+        m_pdfBgDocument->setRenderHint(Poppler::Document::TextAntialiasing);
+    }
+
+    m_pdfTotalPages = m_pdfDocument->numPages();
+    m_pdfCurrentPage = 0;
+    m_pdfFilePath = filePath;
+    m_contentType = ContentType::Pdf;
+    m_imageFilePath.clear();
+    m_pdfPageCache.clear();
+    m_pdfCacheLru.clear();
+
+    // Fast initial render at low DPI for instant display
+    renderPdfPage(0);
+
+    // Schedule async upgrade to full quality
+    if (!m_pixmap.isNull()) {
+        m_pdfRenderTimer->start(PdfPageRenderDelayMs);
+    }
+
+    return !m_pixmap.isNull();
+#else
+    Q_UNUSED(filePath)
+    return false;
+#endif
+}
+
+void QuickLookOverlay::renderPdfPage(int pageIndex)
+{
+#ifdef HAVE_POPPLER
+    if (!m_pdfDocument || pageIndex < 0 || pageIndex >= m_pdfTotalPages) {
+        return;
+    }
+
+    m_pdfCurrentPage = pageIndex;
+    m_hiResLowResPixmap = QPixmap();
+    m_hiResCrossfading = false;
+
+    // Check cache first — instant page switch for visited pages
+    const QPixmap cached = pdfCacheLookup(pageIndex);
+    if (!cached.isNull()) {
+        m_pixmap = cached;
+        m_pdfRenderedDpi = PdfBaseDpi;
+        updatePdfStatusText();
+        return;
+    }
+
+    // Fast render at low DPI (72) on main thread — lightweight enough to not block
+    m_pdfPage = m_pdfDocument->page(pageIndex);
+    if (!m_pdfPage) {
+        return;
+    }
+
+    const QImage image = m_pdfPage->renderToImage(PdfFastDpi, PdfFastDpi);
+    if (image.isNull()) {
+        return;
+    }
+
+    m_pixmap = QPixmap::fromImage(image);
+    m_pdfRenderedDpi = PdfFastDpi;
+    updatePdfStatusText();
+#else
+    Q_UNUSED(pageIndex)
+#endif
+}
+
+void QuickLookOverlay::updatePdfStatusText()
+{
+    m_statusText = (m_pdfTotalPages > 1)
+        ? QStringLiteral(" — Page %1 of %2").arg(m_pdfCurrentPage + 1).arg(m_pdfTotalPages)
+        : QStringLiteral(" — 1 page");
+}
+
+void QuickLookOverlay::navigatePdfPage(int direction)
+{
+#ifdef HAVE_POPPLER
+    if (m_contentType != ContentType::Pdf || m_pdfTotalPages <= 1) {
+        return;
+    }
+
+    const int newPage = m_pdfCurrentPage + direction;
+    if (newPage < 0 || newPage >= m_pdfTotalPages) {
+        return;
+    }
+
+    // Don't navigate while an async page render is pending
+    if (m_pageRenderPending) {
+        return;
+    }
+
+    // Stop scheduled hi-res renders; stale results are discarded
+    // by onHiResRenderFinished via page index mismatch check
+    m_pdfRenderTimer->stop();
+
+    // Reset zoom when changing pages
+    resetZoom();
+
+    // renderPdfPage tries cache first, then does fast 72 DPI render
+    renderPdfPage(newPage);
+
+    // Schedule async upgrade to full DPI + prefetch neighbors
+    m_pdfRenderTimer->start(PdfPageRenderDelayMs);
+
+    update();
+#else
+    Q_UNUSED(direction)
+#endif
+}
+
+void QuickLookOverlay::renderPdfPageAsync(int pageIndex)
+{
+#ifdef HAVE_POPPLER
+    // Ensure only one background task accesses m_pdfBgDocument at a time
+    if (m_pageRenderPending || m_renderPending || !m_pdfBgDocument) {
+        return;
+    }
+
+    // Already cached at full quality? Skip
+    if (m_pdfPageCache.contains(pageIndex)) {
+        return;
+    }
+
+    m_pageRenderPending = true;
+    m_pageRenderTargetPage = pageIndex;
+
+    // Use the persistent background document (already in memory)
+    Poppler::Document *bgDoc = m_pdfBgDocument.get();
+    m_pageRenderWatcher.setFuture(QtConcurrent::run([bgDoc, pageIndex]() -> QImage {
+        auto pg = bgDoc->page(pageIndex);
+        if (!pg) {
+            return {};
+        }
+        return pg->renderToImage(PdfBaseDpi, PdfBaseDpi);
+    }));
+#else
+    Q_UNUSED(pageIndex)
+#endif
+}
+
+void QuickLookOverlay::onPdfPageRenderFinished()
+{
+    m_pageRenderPending = false;
+
+    if (!m_active || m_contentType != ContentType::Pdf) {
+        return;
+    }
+
+    if (m_pageRenderWatcher.isCanceled()) {
+        return;
+    }
+
+    const QImage image = m_pageRenderWatcher.result();
+    if (image.isNull()) {
+        return;
+    }
+
+    const int targetPage = m_pageRenderTargetPage;
+    const QPixmap rendered = QPixmap::fromImage(image);
+
+    // Cache the full-quality render
+    pdfCacheInsert(targetPage, rendered);
+
+    // If this is for the currently displayed page, crossfade to hi-res
+    if (targetPage == m_pdfCurrentPage) {
+        m_hiResLowResPixmap = m_pixmap;
+        m_pixmap = rendered;
+        m_pdfRenderedDpi = PdfBaseDpi;
+
+        m_hiResCrossfade = 0.0;
+        m_hiResCrossfading = true;
+        m_hiResFadeTimer.start();
+        update();
+    }
+
+    // Prefetch adjacent pages
+    prefetchAdjacentPages();
+}
+
+void QuickLookOverlay::prefetchAdjacentPages()
+{
+#ifdef HAVE_POPPLER
+    if (m_pageRenderPending) {
+        return;
+    }
+
+    // Prefetch next page, then previous
+    const int next = m_pdfCurrentPage + 1;
+    const int prev = m_pdfCurrentPage - 1;
+
+    if (next < m_pdfTotalPages && !m_pdfPageCache.contains(next)) {
+        renderPdfPageAsync(next);
+    } else if (prev >= 0 && !m_pdfPageCache.contains(prev)) {
+        renderPdfPageAsync(prev);
+    }
+#endif
+}
+
+#ifdef HAVE_QTMULTIMEDIA
+void QuickLookOverlay::setupVideo(const QUrl &fileUrl)
+{
+    cleanupVideo();
+
+    m_contentType = ContentType::Video;
+    m_videoPhase = VideoPhase::Loading;
+    m_pixmap = QPixmap();
+    m_statusText.clear();
+
+    m_audioOutput = new QAudioOutput(this);
+    m_audioOutput->setVolume(DefaultVolume);
+
+    m_mediaPlayer = new QMediaPlayer(this);
+    m_mediaPlayer->setAudioOutput(m_audioOutput);
+
+    m_videoSink = new QVideoSink(this);
+    m_mediaPlayer->setVideoOutput(m_videoSink);
+
+    m_mediaPlayer->setSource(fileUrl);
+    m_mediaPlayer->setLoops(QMediaPlayer::Infinite);
+
+    m_videoLoadTimer = new QTimer(this);
+    m_videoLoadTimer->setSingleShot(true);
+    connect(m_videoLoadTimer, &QTimer::timeout, this, [this]() {
+        if (m_videoPhase == VideoPhase::Loading) {
+            m_active = false;
+            cleanupVideo();
+            hide();
+            Q_EMIT previewClosed();
+        }
+    });
+    m_videoLoadTimer->start(VideoLoadTimeoutMs);
+
+    connect(m_mediaPlayer, &QMediaPlayer::errorOccurred, this, [this]() {
+        m_active = false;
+        cleanupVideo();
+        hide();
+        Q_EMIT previewClosed();
+    });
+
+    connect(m_videoSink, &QVideoSink::videoFrameChanged, this, [this](const QVideoFrame &frame) {
+        QVideoFrame f = frame;
+        if (!f.isValid()) {
+            return;
+        }
+
+        const QImage image = f.toImage();
+        if (image.isNull()) {
+            return;
+        }
+
+        if (m_videoPhase == VideoPhase::Loading) {
+            // First frame arrived — cancel timeout and use as thumbnail
+            if (m_videoLoadTimer) {
+                m_videoLoadTimer->stop();
+                m_videoLoadTimer->deleteLater();
+                m_videoLoadTimer = nullptr;
+            }
+            m_pixmap = QPixmap::fromImage(image);
+            m_videoPhase = VideoPhase::Animating;
+            m_mediaPlayer->pause();
+
+            if (!parentWidget()) {
+                return;
+            }
+            move(0, 0);
+            resize(parentWidget()->size());
+            show();
+            raise();
+            setFocus();
+            startShowAnimation();
+            return;
+        }
+
+        if (m_videoPhase == VideoPhase::Playing) {
+            // Live frame — update pixmap and repaint
+            m_pixmap = QPixmap::fromImage(image);
+            update();
+        }
+    });
+
+    m_mediaPlayer->play();
+}
+
+void QuickLookOverlay::cleanupVideo()
+{
+    if (m_videoLoadTimer) {
+        m_videoLoadTimer->stop();
+        m_videoLoadTimer->deleteLater();
+        m_videoLoadTimer = nullptr;
+    }
+    if (m_mediaPlayer) {
+        m_mediaPlayer->stop();
+        m_mediaPlayer->deleteLater();
+        m_mediaPlayer = nullptr;
+    }
+    if (m_videoSink) {
+        m_videoSink->deleteLater();
+        m_videoSink = nullptr;
+    }
+    if (m_audioOutput) {
+        m_audioOutput->deleteLater();
+        m_audioOutput = nullptr;
+    }
+}
+#endif
+
+void QuickLookOverlay::pdfCacheInsert(int pageIndex, const QPixmap &pixmap)
+{
+    if (m_pdfPageCache.contains(pageIndex)) {
+        // Move to front of LRU
+        m_pdfCacheLru.removeOne(pageIndex);
+        m_pdfCacheLru.prepend(pageIndex);
+        m_pdfPageCache[pageIndex] = pixmap;
+        return;
+    }
+
+    // Evict oldest if at capacity
+    while (m_pdfCacheLru.size() >= PdfCacheMaxPages) {
+        const int evicted = m_pdfCacheLru.takeLast();
+        m_pdfPageCache.remove(evicted);
+    }
+
+    m_pdfPageCache.insert(pageIndex, pixmap);
+    m_pdfCacheLru.prepend(pageIndex);
+}
+
+QPixmap QuickLookOverlay::pdfCacheLookup(int pageIndex)
+{
+    if (!m_pdfPageCache.contains(pageIndex)) {
+        return {};
+    }
+
+    // Move to front of LRU
+    m_pdfCacheLru.removeOne(pageIndex);
+    m_pdfCacheLru.prepend(pageIndex);
+
+    return m_pdfPageCache.value(pageIndex);
+}
+
+void QuickLookOverlay::showPreview(const QUrl &fileUrl)
+{
+    // Cancel any in-progress animation to avoid race conditions
+    m_animating = false;
+
+    if (!fileUrl.isLocalFile()) {
+        return;
+    }
+
+    const QString filePath = fileUrl.toLocalFile();
+    QMimeDatabase mimeDb;
+    const QString mimeType = mimeDb.mimeTypeForFile(filePath).name();
+
+    bool loaded = false;
+
+    if (mimeType.startsWith(QLatin1String("image/"))) {
+        loaded = loadImage(filePath);
+    } else if (mimeType == QLatin1String("application/pdf")) {
+        loaded = loadPdf(filePath);
+    }
+#ifdef HAVE_QTMULTIMEDIA
+    else if (mimeType.startsWith(QLatin1String("video/"))) {
+        m_currentUrl = fileUrl;
+        m_active = true;
+        resetZoom();
+        setupVideo(fileUrl);
+        return;
+    }
+#endif
+
+    if (!loaded) {
+        return;
+    }
+
+    m_currentUrl = fileUrl;
+    m_active = true;
+    resetZoom();
+
+    if (!parentWidget()) {
+        return;
+    }
+    move(0, 0);
+    resize(parentWidget()->size());
+    show();
+    raise();
+    setFocus();
+
+    startShowAnimation();
+}
+
+void QuickLookOverlay::hidePreview()
+{
+    if (!m_active) {
+        return;
+    }
+
+#ifdef HAVE_QTMULTIMEDIA
+    if (m_contentType == ContentType::Video) {
+        // m_pixmap already has the last rendered frame
+        if (m_mediaPlayer) {
+            m_mediaPlayer->pause();
+        }
+        m_videoPhase = VideoPhase::Closing;
+    }
+#endif
+
+    startHideAnimation();
+}
+
+bool QuickLookOverlay::isPreviewActive() const
+{
+    return m_active;
+}
+
+qreal QuickLookOverlay::animationProgress() const
+{
+    return m_animationProgress;
+}
+
+void QuickLookOverlay::setAnimationProgress(qreal progress)
+{
+    m_animationProgress = progress;
+    update();
+}
+
+void QuickLookOverlay::advanceAnimation()
+{
+    if (!m_animating) {
+        return;
+    }
+
+    const qreal elapsed = static_cast<qreal>(m_animTimer.elapsed());
+    const qreal duration = qMax(1.0, static_cast<qreal>(m_animDuration));
+    const qreal t = qBound(0.0, elapsed / duration, 1.0);
+    const qreal easedT = m_easingCurve.valueForProgress(t);
+    m_animationProgress = m_animStartValue + (m_animEndValue - m_animStartValue) * easedT;
+
+    if (t >= 1.0) {
+        m_animating = false;
+        onAnimationFinished();
+    }
+}
+
+void QuickLookOverlay::onAnimationFinished()
+{
+    if (m_animForward) {
+#ifdef HAVE_QTMULTIMEDIA
+        if (m_contentType == ContentType::Video && m_videoPhase == VideoPhase::Animating && m_mediaPlayer) {
+            m_videoPhase = VideoPhase::Playing;
+            m_mediaPlayer->play();
+        }
+#endif
+    } else {
+        m_active = false;
+        m_pixmap = QPixmap();
+#ifdef HAVE_POPPLER
+        m_pdfPage.reset();
+        m_pdfDocument.reset();
+        m_pdfBgDocument.reset();
+        m_pdfPageCache.clear();
+        m_pdfCacheLru.clear();
+#endif
+#ifdef HAVE_QTMULTIMEDIA
+        cleanupVideo();
+#endif
+        hide();
+        Q_EMIT previewClosed();
+    }
+}
+
+void QuickLookOverlay::advanceZoomAnimation()
+{
+    if (!m_zoomAnimating) {
+        return;
+    }
+
+    const qreal elapsed = static_cast<qreal>(m_zoomAnimTimer.elapsed());
+    const qreal duration = qMax(1.0, static_cast<qreal>(m_zoomAnimDuration));
+    const qreal t = qBound(0.0, elapsed / duration, 1.0);
+    const qreal easedT = m_easingCurve.valueForProgress(t);
+
+    m_zoomFactor = m_zoomAnimStartFactor + (1.0 - m_zoomAnimStartFactor) * easedT;
+    m_panOffset = m_zoomAnimStartPan * (1.0 - easedT);
+
+    if (t >= 1.0) {
+        m_zoomAnimating = false;
+        m_zoomFactor = 1.0;
+        m_panOffset = QPointF(0, 0);
+        setCursor(Qt::ArrowCursor);
+    }
+}
+
+void QuickLookOverlay::animateZoomReset()
+{
+    m_zoomAnimStartFactor = m_zoomFactor;
+    m_zoomAnimStartPan = m_panOffset;
+    m_zoomAnimating = true;
+    m_zoomAnimTimer.start();
+    m_dragging = false;
+    update();
+}
+
+void QuickLookOverlay::scheduleHiResRerender()
+{
+    if (m_contentType == ContentType::Pdf) {
+#ifdef HAVE_POPPLER
+        const qreal targetDpi = qBound(PdfBaseDpi, PdfBaseDpi * m_zoomFactor, PdfMaxDpi);
+        const qreal ratio = targetDpi / m_pdfRenderedDpi;
+        // Re-render if target differs significantly (up or down)
+        if (ratio > 0.85 && ratio < 1.15) {
+            return;
+        }
+        m_pdfRenderTimer->start(PdfRerenderDelayMs);
+#endif
+    } else if (m_contentType == ContentType::Image && !m_imageFilePath.isEmpty()) {
+        if (!m_imageOriginalSize.isValid() || m_pixmap.isNull()) {
+            return;
+        }
+
+        const QRectF base = baseContentRect();
+        const int targetWidth = qBound(
+            static_cast<int>(base.width()),
+            static_cast<int>(base.width() * m_zoomFactor),
+            m_imageOriginalSize.width());
+        const qreal ratio = static_cast<qreal>(targetWidth) / m_imageRenderedWidth;
+        if (ratio > 0.85 && ratio < 1.15) {
+            return;
+        }
+
+        m_pdfRenderTimer->start(PdfRerenderDelayMs);
+    }
+}
+
+void QuickLookOverlay::rerenderHiRes()
+{
+    // Don't start a new render if one is already running
+    if (m_renderPending) {
+        // Re-schedule to pick up the latest zoom after current render finishes
+        m_pdfRenderTimer->start(PdfRerenderDelayMs);
+        return;
+    }
+
+    if (m_contentType == ContentType::Pdf) {
+#ifdef HAVE_POPPLER
+        if (!m_pdfPage) {
+            return;
+        }
+
+        // If we're at base DPI from a cached page and no zoom, just upgrade
+        // the current page from fast DPI to base DPI via async render
+        if (m_pdfRenderedDpi < PdfBaseDpi && qFuzzyCompare(m_zoomFactor, 1.0)) {
+            renderPdfPageAsync(m_pdfCurrentPage);
+            return;
+        }
+
+        const qreal targetDpi = qBound(PdfBaseDpi, PdfBaseDpi * m_zoomFactor, PdfMaxDpi);
+        const qreal ratio = targetDpi / m_pdfRenderedDpi;
+        if (ratio > 0.85 && ratio < 1.15) {
+            return;
+        }
+
+        // Don't start zoom hi-res render if page render is still running
+        if (m_pageRenderPending) {
+            m_pdfRenderTimer->start(PdfRerenderDelayMs);
+            return;
+        }
+
+        m_renderTargetDpi = targetDpi;
+        m_renderPending = true;
+        m_renderPageIndex = m_pdfCurrentPage;
+
+        // Use persistent background document (already in memory)
+        // instead of reloading large files from disk
+        const QString filePath = m_pdfFilePath;
+        const qreal dpi = targetDpi;
+        const int pageIndex = m_pdfCurrentPage;
+
+        if (m_pdfBgDocument) {
+            Poppler::Document *bgDoc = m_pdfBgDocument.get();
+            m_renderWatcher.setFuture(QtConcurrent::run([bgDoc, dpi, pageIndex]() -> QImage {
+                auto pg = bgDoc->page(pageIndex);
+                if (!pg) {
+                    return {};
+                }
+                return pg->renderToImage(dpi, dpi);
+            }));
+        } else {
+            // Fallback: reload from disk if background document unavailable
+            m_renderWatcher.setFuture(QtConcurrent::run([filePath, dpi, pageIndex]() -> QImage {
+                auto doc = Poppler::Document::load(filePath);
+                if (!doc) {
+                    return {};
+                }
+                doc->setRenderHint(Poppler::Document::Antialiasing);
+                doc->setRenderHint(Poppler::Document::TextAntialiasing);
+                auto pg = doc->page(pageIndex);
+                if (!pg) {
+                    return {};
+                }
+                return pg->renderToImage(dpi, dpi);
+            }));
+        }
+#endif
+    } else if (m_contentType == ContentType::Image && !m_imageFilePath.isEmpty()) {
+        const QRectF base = baseContentRect();
+        const int targetWidth = qBound(
+            static_cast<int>(base.width()),
+            static_cast<int>(base.width() * m_zoomFactor),
+            m_imageOriginalSize.width());
+        const qreal ratio = static_cast<qreal>(targetWidth) / m_imageRenderedWidth;
+        if (ratio > 0.85 && ratio < 1.15) {
+            return;
+        }
+
+        m_renderPending = true;
+
+        const QString filePath = m_imageFilePath;
+        const QSize origSize = m_imageOriginalSize;
+        const int tw = targetWidth;
+        m_renderWatcher.setFuture(QtConcurrent::run([filePath, origSize, tw]() -> QImage {
+            QImageReader reader(filePath);
+            reader.setAutoTransform(true);
+
+            QSize scaledSize = origSize;
+            scaledSize.scale(tw, tw * origSize.height() / origSize.width(), Qt::KeepAspectRatio);
+            reader.setScaledSize(scaledSize);
+
+            return reader.read();
+        }));
+    }
+}
+
+void QuickLookOverlay::onHiResRenderFinished()
+{
+    m_renderPending = false;
+
+    if (!m_active) {
+        return;
+    }
+
+    // Discard result if page changed since this render was started
+    if (m_renderWatcher.isCanceled()) {
+        return;
+    }
+
+    // Discard stale hi-res render for a different page
+    if (m_contentType == ContentType::Pdf && m_renderPageIndex != m_pdfCurrentPage) {
+        return;
+    }
+
+    const QImage image = m_renderWatcher.result();
+    if (image.isNull()) {
+        return;
+    }
+
+    m_hiResLowResPixmap = m_pixmap;
+    m_pixmap = QPixmap::fromImage(image);
+
+    if (m_contentType == ContentType::Pdf) {
+        m_pdfRenderedDpi = m_renderTargetDpi;
+    } else if (m_contentType == ContentType::Image) {
+        m_imageRenderedWidth = m_pixmap.width();
+    }
+
+    m_hiResCrossfade = 0.0;
+    m_hiResCrossfading = true;
+    m_hiResFadeTimer.start();
+    update();
+}
+
+void QuickLookOverlay::paintEvent(QPaintEvent *event)
+{
+    Q_UNUSED(event)
+
+    advanceAnimation();
+    advanceZoomAnimation();
+
+    if (m_pixmap.isNull()) {
+        if (m_animating || m_zoomAnimating) {
+            update();
+        }
+        return;
+    }
+
+    QPainter painter(this);
+    painter.setRenderHint(QPainter::Antialiasing);
+    painter.setRenderHint(QPainter::SmoothPixmapTransform);
+
+    // Theme-independent colors: semi-transparent black overlay, white text
+    const QColor bgColor(0, 0, 0, static_cast<int>(BgAlphaMax * m_animationProgress));
+    QColor shadowColor(0, 0, 0);
+    const QColor textColor(255, 255, 255, static_cast<int>(255 * m_animationProgress));
+    QFont labelFont = font();
+    labelFont.setBold(true);
+
+    // Background
+    painter.fillRect(rect(), bgColor);
+
+    const QRect targetRect = scaledContentRect();
+
+#ifdef HAVE_QTMULTIMEDIA
+    // During live video playback — draw frame at full size, no scale animation
+    if (m_contentType == ContentType::Video && m_videoPhase == VideoPhase::Playing) {
+        // Drop shadow
+        shadowColor.setAlpha(ShadowAlphaMax);
+        QRectF shadowRect = QRectF(targetRect).adjusted(0, 0, ShadowOffset, ShadowOffset);
+        painter.setPen(Qt::NoPen);
+        painter.setBrush(shadowColor);
+        painter.drawRoundedRect(shadowRect, CornerRadius, CornerRadius);
+
+        // Video frame with rounded corners
+        QPainterPath clipPath;
+        clipPath.addRoundedRect(QRectF(targetRect), CornerRadius, CornerRadius);
+        painter.setClipPath(clipPath);
+        painter.drawPixmap(targetRect, m_pixmap);
+        painter.setClipping(false);
+
+        // Filename
+        painter.setPen(textColor);
+        painter.setFont(labelFont);
+        const QRect textRect(0, targetRect.bottom() + TextSpacing, width(), TextHeight);
+        painter.drawText(textRect, Qt::AlignHCenter | Qt::AlignTop, m_currentUrl.fileName());
+        if (m_animating || m_zoomAnimating) {
+            update();
+        }
+        return;
+    }
+#endif
+
+    // Image / PDF / Video thumbnail with scale animation
+    const QPointF center = QRectF(targetRect).center();
+    const qreal scale = 0.3 + 0.7 * m_animationProgress;
+    const qreal w = targetRect.width() * scale;
+    const qreal h = targetRect.height() * scale;
+    const QRectF drawRect(center.x() - w / 2.0, center.y() - h / 2.0, w, h);
+
+    // Drop shadow
+    const int curShadowOffset = static_cast<int>(ShadowOffset * m_animationProgress);
+    shadowColor.setAlpha(static_cast<int>(ShadowAlphaMax * m_animationProgress));
+    QRectF shadowRect = drawRect.adjusted(curShadowOffset, curShadowOffset, curShadowOffset, curShadowOffset);
+    painter.setPen(Qt::NoPen);
+    painter.setBrush(shadowColor);
+    painter.drawRoundedRect(shadowRect, CornerRadius, CornerRadius);
+
+    // Content with rounded corners + fade
+    painter.setOpacity(m_animationProgress);
+    QPainterPath clipPath;
+    clipPath.addRoundedRect(drawRect, CornerRadius, CornerRadius);
+    painter.setClipPath(clipPath);
+
+    // PDF crossfade: blend old low-res into new high-res
+    if (m_hiResCrossfading && !m_hiResLowResPixmap.isNull()) {
+        const qreal elapsed = static_cast<qreal>(m_hiResFadeTimer.elapsed());
+        m_hiResCrossfade = qBound(0.0, elapsed / PdfCrossfadeDurationMs, 1.0);
+
+        // Draw old (fading out)
+        painter.setOpacity(m_animationProgress * (1.0 - m_hiResCrossfade));
+        painter.drawPixmap(drawRect.toRect(), m_hiResLowResPixmap);
+
+        // Draw new (fading in)
+        painter.setOpacity(m_animationProgress * m_hiResCrossfade);
+        painter.drawPixmap(drawRect.toRect(), m_pixmap);
+
+        if (m_hiResCrossfade >= 1.0) {
+            m_hiResCrossfading = false;
+            m_hiResLowResPixmap = QPixmap();
+        }
+    } else {
+        painter.drawPixmap(drawRect.toRect(), m_pixmap);
+    }
+
+    painter.setClipping(false);
+    painter.setOpacity(1.0);
+
+    // Filename + status
+    const QString label = m_currentUrl.fileName() + m_statusText;
+    painter.setPen(textColor);
+    painter.setFont(labelFont);
+    const QRect textRect(0, drawRect.bottom() + TextSpacing, width(), TextHeight);
+    painter.drawText(textRect, Qt::AlignHCenter | Qt::AlignTop, label);
+
+    // PDF page navigation arrows (up/down)
+    if (m_contentType == ContentType::Pdf && m_pdfTotalPages > 1 && m_animationProgress > 0.5) {
+        const int arrowSize = 36;
+        const int arrowMargin = 16;
+        const int arrowX = drawRect.right() + arrowMargin;
+        const int centerY = drawRect.center().y();
+
+        // Arrow up
+        m_pdfArrowUpRect = QRect(arrowX, centerY - arrowSize - 4, arrowSize, arrowSize);
+        // Arrow down
+        m_pdfArrowDownRect = QRect(arrowX, centerY + 4, arrowSize, arrowSize);
+
+        const bool canGoUp = m_pdfCurrentPage > 0;
+        const bool canGoDown = m_pdfCurrentPage < m_pdfTotalPages - 1;
+
+        auto drawArrowButton = [&](const QRect &btnRect, bool enabled, bool pointsUp) {
+            const qreal btnOpacity = enabled ? 0.85 : 0.3;
+            painter.setOpacity(m_animationProgress * btnOpacity);
+
+            // Button background
+            painter.setPen(Qt::NoPen);
+            painter.setBrush(QColor(255, 255, 255, 40));
+            painter.drawRoundedRect(btnRect, 8, 8);
+
+            // Arrow triangle
+            const int pad = 10;
+            const QPointF c = QRectF(btnRect).center();
+            const int half = (arrowSize - 2 * pad) / 2;
+            QPolygonF triangle;
+            if (pointsUp) {
+                triangle << QPointF(c.x(), c.y() - half)
+                         << QPointF(c.x() - half, c.y() + half)
+                         << QPointF(c.x() + half, c.y() + half);
+            } else {
+                triangle << QPointF(c.x(), c.y() + half)
+                         << QPointF(c.x() - half, c.y() - half)
+                         << QPointF(c.x() + half, c.y() - half);
+            }
+            painter.setBrush(QColor(255, 255, 255));
+            painter.drawPolygon(triangle);
+        };
+
+        drawArrowButton(m_pdfArrowUpRect, canGoUp, true);
+        drawArrowButton(m_pdfArrowDownRect, canGoDown, false);
+
+        painter.setOpacity(1.0);
+    } else {
+        m_pdfArrowUpRect = QRect();
+        m_pdfArrowDownRect = QRect();
+    }
+
+    // Schedule next frame if animation is still running
+    if (m_animating || m_zoomAnimating || m_hiResCrossfading) {
+        update();
+    }
+}
+
+void QuickLookOverlay::mouseDoubleClickEvent(QMouseEvent *event)
+{
+    Q_UNUSED(event)
+    hidePreview();
+}
+
+void QuickLookOverlay::mousePressEvent(QMouseEvent *event)
+{
+    // PDF page navigation arrow clicks
+    if (event->button() == Qt::LeftButton && m_contentType == ContentType::Pdf && m_pdfTotalPages > 1) {
+        const QPoint pos = event->pos();
+        if (m_pdfArrowUpRect.contains(pos) && m_pdfCurrentPage > 0) {
+            navigatePdfPage(-1);
+            event->accept();
+            return;
+        }
+        if (m_pdfArrowDownRect.contains(pos) && m_pdfCurrentPage < m_pdfTotalPages - 1) {
+            navigatePdfPage(1);
+            event->accept();
+            return;
+        }
+    }
+
+    if (event->button() == Qt::RightButton && m_zoomFactor > ZoomMin) {
+        animateZoomReset();
+        event->accept();
+        return;
+    }
+    if (event->button() == Qt::LeftButton && m_zoomFactor > ZoomMin) {
+        m_dragging = true;
+        m_lastMousePos = event->position();
+        setCursor(Qt::ClosedHandCursor);
+        event->accept();
+        return;
+    }
+    QWidget::mousePressEvent(event);
+}
+
+void QuickLookOverlay::mouseMoveEvent(QMouseEvent *event)
+{
+    if (m_dragging) {
+        const QPointF delta = event->position() - m_lastMousePos;
+        m_panOffset += delta;
+        m_lastMousePos = event->position();
+        update();
+        event->accept();
+        return;
+    }
+    QWidget::mouseMoveEvent(event);
+}
+
+void QuickLookOverlay::mouseReleaseEvent(QMouseEvent *event)
+{
+    if (event->button() == Qt::LeftButton && m_dragging) {
+        m_dragging = false;
+        setCursor(m_zoomFactor > ZoomMin ? Qt::OpenHandCursor : Qt::ArrowCursor);
+        event->accept();
+        return;
+    }
+    QWidget::mouseReleaseEvent(event);
+}
+
+void QuickLookOverlay::wheelEvent(QWheelEvent *event)
+{
+    if (!m_active || m_animating || m_zoomAnimating) {
+        event->ignore();
+        return;
+    }
+
+    // Only zoom when cursor is over the content area
+    const QRect contentArea = scaledContentRect();
+    const QPointF cursorPos = event->position();
+    if (!contentArea.contains(cursorPos.toPoint())) {
+        event->accept();
+        return;
+    }
+
+    const qreal oldZoom = m_zoomFactor;
+    const qreal delta = event->angleDelta().y() > 0 ? ZoomStep : -ZoomStep;
+    m_zoomFactor = qBound(ZoomMin, m_zoomFactor + delta * m_zoomFactor, ZoomMax);
+
+    if (qFuzzyCompare(m_zoomFactor, oldZoom)) {
+        event->accept();
+        return;
+    }
+
+    // Zoom toward cursor: keep the content point under cursor fixed.
+    // panOffset is relative to baseContentRect center, so we must
+    // express cursorPos relative to that same center.
+    const QRectF base = baseContentRect();
+    const QPointF baseCenter = base.center();
+    const qreal ratio = m_zoomFactor / oldZoom;
+    m_panOffset = (1.0 - ratio) * (cursorPos - baseCenter) + ratio * m_panOffset;
+
+    // Reset pan when back to 1.0
+    if (qFuzzyCompare(m_zoomFactor, ZoomMin)) {
+        m_panOffset = QPointF(0, 0);
+        setCursor(Qt::ArrowCursor);
+    } else {
+        setCursor(Qt::OpenHandCursor);
+    }
+
+    scheduleHiResRerender();
+
+    update();
+    event->accept();
+}
+
+void QuickLookOverlay::keyPressEvent(QKeyEvent *event)
+{
+    if (event->key() == Qt::Key_Escape || event->key() == Qt::Key_Space) {
+        hidePreview();
+        event->accept();
+        return;
+    }
+
+    if (m_contentType == ContentType::Pdf && m_pdfTotalPages > 1) {
+        if (event->key() == Qt::Key_Up || event->key() == Qt::Key_PageUp) {
+            navigatePdfPage(-1);
+            event->accept();
+            return;
+        }
+        if (event->key() == Qt::Key_Down || event->key() == Qt::Key_PageDown) {
+            navigatePdfPage(1);
+            event->accept();
+            return;
+        }
+    }
+
+    QWidget::keyPressEvent(event);
+}
+
+void QuickLookOverlay::resizeEvent(QResizeEvent *event)
+{
+    QWidget::resizeEvent(event);
+    update();
+}
+
+void QuickLookOverlay::startShowAnimation()
+{
+    m_animStartValue = m_animationProgress;
+    m_animEndValue = 1.0;
+    m_animForward = true;
+    m_animating = true;
+    m_animTimer.start();
+    update();
+}
+
+void QuickLookOverlay::startHideAnimation()
+{
+    m_animStartValue = m_animationProgress;
+    m_animEndValue = 0.0;
+    m_animForward = false;
+    m_animating = true;
+    m_animTimer.start();
+    update();
+}
+
+void QuickLookOverlay::resetZoom()
+{
+    m_zoomFactor = 1.0;
+    m_panOffset = QPointF(0, 0);
+    m_dragging = false;
+    setCursor(Qt::ArrowCursor);
+}
+
+QRectF QuickLookOverlay::baseContentRect() const
+{
+    const int maxW = width() - 2 * ContentPadding;
+    const int maxH = height() - 2 * ContentPadding - BottomExtraSpace;
+
+    QSize contentSize;
+    if (!m_pixmap.isNull()) {
+        contentSize = m_pixmap.size();
+    } else {
+        return {};
+    }
+
+    contentSize.scale(maxW, maxH, Qt::KeepAspectRatio);
+
+    const qreal x = (width() - contentSize.width()) / 2.0;
+    const qreal y = (height() - contentSize.height()) / 2.0 - ContentVerticalShift;
+
+    return {x, y, static_cast<qreal>(contentSize.width()), static_cast<qreal>(contentSize.height())};
+}
+
+QRect QuickLookOverlay::scaledContentRect() const
+{
+    const QRectF base = baseContentRect();
+    if (base.isEmpty()) {
+        return {};
+    }
+
+    const qreal w = base.width() * m_zoomFactor;
+    const qreal h = base.height() * m_zoomFactor;
+    const qreal cx = base.center().x() + m_panOffset.x();
+    const qreal cy = base.center().y() + m_panOffset.y();
+
+    return QRectF(cx - w / 2.0, cy - h / 2.0, w, h).toRect();
+}
