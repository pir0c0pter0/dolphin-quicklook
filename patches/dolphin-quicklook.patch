+void QuickLookOverlay::startPdfSpinner()
+{
+    if (!m_spinnerTimer) {
+        m_spinnerTimer = new QTimer(this);
+        connect(m_spinnerTimer, &QTimer::timeout, this, [this]() {
+            m_spinnerAngle += 30.0;
+            if (m_spinnerAngle >= 360.0) {
+                m_spinnerAngle -= 360.0;
+            }
+            update();
+        });
+    }
+    m_spinnerAngle = 0.0;
+    m_spinnerTimer->start(50);
+}
+
+void QuickLookOverlay::stopPdfSpinner()
+{
+    if (m_spinnerTimer) {
+        m_spinnerTimer->stop();
+    }
+    m_pdfPageLoading = false;
+    m_spinnerAngle = 0.0;
+}
